---
import BaseLayout from "../layouts/BaseLayout.astro";
import SeoPageHero from "../components/SeoPageHero.astro";
import FeaturedProductsSection from "../components/FeaturedProductsSection.astro";
import LeadCaptureSection from "../components/LeadCaptureSection.astro";
import BranchesSection from "../components/BranchesSection.astro";
import FAQSection from "../components/FAQSection.astro";
import FinalCtaSection from "../components/FinalCtaSection.astro";
---

<BaseLayout
  title="Tyres Dubai | Buy Premium Tyres in Dubai UAE | Khalid Amin Tyres"
  description="Buy tyres in Dubai with fast WhatsApp pricing. Khalid Amin Tyres offers premium tyres, fitting, balancing and tyre services in Dubai and Sharjah."
  metaTitleKey="meta_tyres_dubai_title"
  metaDescriptionKey="meta_tyres_dubai_description"
>
  <main>
    <SeoPageHero
      imageKey="tyres_dubai_hero"
      badge="Tyres Dubai"
      titleKey="tyres_dubai_hero_title"
      subtitleKey="tyres_dubai_hero_subtitle"
      title="Buy Tyres in Dubai"
      subtitle="Looking for tyres in Dubai? Get fast pricing, availability and fitting support from Khalid Amin Tyres."
      branch="dubai"
      bullets={[
        "Premium tyre brands",
        "Tyre fitting support",
        "Wheel balancing",
        "Fast WhatsApp pricing",
      ]}
    />

    <FeaturedProductsSection
      productType="tyre"
      branch="dubai"
      featuredOnly={false}
      limit={12}
      badge="Tyres Available in Dubai"
      title="Shop tyres available from our Dubai branch"
      subtitle="Browse active tyre options available for Dubai customers, including tyre size, year, origin, vehicle type and direct WhatsApp pricing."
      emptyText="No active Dubai tyres are available right now. Please contact us on WhatsApp for current stock."
    />

    <LeadCaptureSection />
    <BranchesSection />
    <FAQSection />
    <FinalCtaSection />
  </main>
</BaseLayout>
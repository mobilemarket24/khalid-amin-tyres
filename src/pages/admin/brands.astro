---
import "../../styles/global.css";
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminShell from "../../components/admin/AdminShell.astro";
---

<AdminLayout title="Brands | Khalid Amin Tyres Admin">
  <AdminShell title="Brands" eyebrow="Brand Management" current="brands">
    <div class="space-y-6">
      <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
        <form
          id="brandForm"
          class="rounded-[2rem] border border-white/10 bg-white/10 p-6"
        >
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.2em] text-amber-300">
                Brand Form
              </p>

              <h3 id="formTitle" class="mt-2 text-2xl font-black">
                Add Brand
              </h3>
            </div>

            <button
              id="resetButton"
              type="button"
              class="hidden rounded-2xl bg-white/10 px-4 py-3 text-sm font-black text-white transition hover:bg-white/15"
            >
              Cancel Edit
            </button>
          </div>

          <input id="brandId" type="hidden" />

          <div class="mt-6 grid gap-5">
            <div>
              <label class="mb-2 block text-sm font-black text-slate-300">
                Brand Name
              </label>
              <input
                id="brandName"
                required
                class="field"
                placeholder="Michelin"
              />
            </div>

            <div>
              <label class="mb-2 block text-sm font-black text-slate-300">
                Slug
              </label>
              <input
                id="brandSlug"
                required
                class="field"
                placeholder="michelin"
              />
              <p class="mt-2 text-xs font-semibold text-slate-500">
                برای لینک و دیتابیس استفاده می‌شود. فقط انگلیسی و خط تیره.
              </p>
            </div>

            <div>
              <label class="mb-2 block text-sm font-black text-slate-300">
                Country
              </label>
              <input
                id="brandCountry"
                class="field"
                placeholder="France / Japan / Germany / USA..."
              />
            </div>

            <div>
              <label class="mb-2 block text-sm font-black text-slate-300">
                Logo URL
              </label>
              <input
                id="brandLogoUrl"
                class="field"
                placeholder="https://..."
              />
              <p class="mt-2 text-xs font-semibold text-slate-500">
                می‌توانید لینک لوگو را بگذارید، یا از پایین یک فایل لوگو آپلود کنید.
              </p>

              <div class="mt-4 rounded-2xl border border-amber-400/30 bg-amber-400/10 p-4">
                <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-amber-300">
                  آپلود فایل لوگو (PNG / SVG / WebP)
                </label>
                <input
                  id="brandLogoFile"
                  type="file"
                  accept="image/png,image/svg+xml,image/webp,image/jpeg"
                  class="w-full text-sm font-semibold text-slate-200 file:mr-3 file:rounded-xl file:border-0 file:bg-amber-400 file:px-4 file:py-2 file:font-black file:text-slate-950"
                />
                <p class="mt-2 text-xs font-semibold text-slate-500">
                  لوگوی شفاف (PNG/SVG) بهترین نتیجه را می‌دهد. هنگام ذخیره، فایل آپلود و لینکش خودکار ثبت می‌شود.
                </p>

                <div id="logoPreviewWrap" class="mt-3 hidden">
                  <p class="mb-2 text-xs font-black uppercase tracking-[0.18em] text-slate-500">پیش‌نمایش</p>
                  <img
                    id="logoPreview"
                    alt="Logo preview"
                    class="h-14 w-auto max-w-[160px] rounded-xl bg-white object-contain p-2"
                  />
                </div>
              </div>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-sm font-black text-slate-300">
                  Sort Order
                </label>
                <input
                  id="brandSortOrder"
                  type="number"
                  class="field"
                  placeholder="10"
                />
              </div>

              <div>
                <label class="mb-2 block text-sm font-black text-slate-300">
                  Status
                </label>
                <select id="brandIsActive" class="field">
                  <option value="true">Active</option>
                  <option value="false">Hidden</option>
                </select>
              </div>
            </div>
          </div>

          <div id="message" class="mt-5 hidden rounded-2xl p-4 text-sm font-bold"></div>

          <button
            id="saveButton"
            type="submit"
            class="mt-6 w-full rounded-2xl bg-amber-400 px-6 py-4 font-black text-slate-950 transition hover:bg-amber-300"
          >
            Save Brand
          </button>
        </form>

        <div class="rounded-[2rem] border border-white/10 bg-white/10 p-6">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-red-300">
            Summary
          </p>

          <div class="mt-6 grid gap-4 sm:grid-cols-3 xl:grid-cols-1">
            <div class="rounded-[1.5rem] bg-slate-950/60 p-5">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">
                Total Brands
              </p>
              <p id="totalBrands" class="mt-3 text-4xl font-black">0</p>
            </div>

            <div class="rounded-[1.5rem] bg-green-500/10 p-5">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-green-300">
                Active
              </p>
              <p id="activeBrands" class="mt-3 text-4xl font-black text-green-200">0</p>
            </div>

            <div class="rounded-[1.5rem] bg-red-500/10 p-5">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-red-300">
                Hidden
              </p>
              <p id="hiddenBrands" class="mt-3 text-4xl font-black text-red-200">0</p>
            </div>
          </div>

          <div class="mt-6 rounded-[1.5rem] border border-white/10 bg-slate-950/60 p-5">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">
              Note
            </p>
            <p class="mt-3 text-sm font-semibold leading-7 text-slate-300">
              برندهایی که Hidden شوند، در سایت عمومی نمایش داده نمی‌شوند، ولی محصولات قدیمی‌شان از دیتابیس پاک نمی‌شود.
            </p>
          </div>
        </div>
      </div>

      <div class="grid gap-4 rounded-[2rem] border border-white/10 bg-white/10 p-5 lg:grid-cols-[1fr_0.5fr]">
        <input
          id="searchInput"
          type="search"
          placeholder="Search brand..."
          class="rounded-2xl border border-white/10 bg-slate-950 px-5 py-4 font-bold text-white outline-none ring-amber-300/30 transition focus:ring-4"
        />

        <select
          id="statusFilter"
          class="rounded-2xl border border-white/10 bg-slate-950 px-5 py-4 font-bold text-white outline-none ring-amber-300/30 transition focus:ring-4"
        >
          <option value="all">All Status</option>
          <option value="active">Active</option>
          <option value="hidden">Hidden</option>
        </select>
      </div>

      <div id="loading" class="rounded-[2rem] border border-white/10 bg-white/10 p-8 text-center font-black">
        Loading brands...
      </div>

      <div id="errorBox" class="hidden rounded-[2rem] bg-red-500/20 p-8 font-bold text-red-200"></div>

      <div id="emptyBox" class="hidden rounded-[2rem] border border-white/10 bg-white/10 p-8 text-center">
        <h3 class="text-2xl font-black">No brands found</h3>
        <p class="mt-3 text-sm font-semibold text-slate-400">
          Add your first brand from the form above.
        </p>
      </div>

      <div id="brandsWrap" class="hidden overflow-hidden rounded-[2rem] border border-white/10 bg-white/10">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[900px] text-left">
            <thead class="bg-slate-950/70 text-xs uppercase tracking-[0.2em] text-slate-400">
              <tr>
                <th class="px-5 py-4">Brand</th>
                <th class="px-5 py-4">Country</th>
                <th class="px-5 py-4">Sort</th>
                <th class="px-5 py-4">Status</th>
                <th class="px-5 py-4 text-right">Actions</th>
              </tr>
            </thead>

            <tbody id="brandsTable" class="divide-y divide-white/10"></tbody>
          </table>
        </div>
      </div>
    </div>
  </AdminShell>

  <style>
    .field {
      width: 100%;
      border-radius: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: #020617;
      padding: 1rem 1.25rem;
      color: white;
      outline: none;
    }

    .field:focus {
      box-shadow: 0 0 0 4px rgba(103, 232, 249, 0.25);
    }
  </style>

  <script>
    import { supabase } from "../../lib/supabase";

    const brandForm = document.getElementById("brandForm");
    const formTitle = document.getElementById("formTitle");
    const resetButton = document.getElementById("resetButton");
    const saveButton = document.getElementById("saveButton");
    const message = document.getElementById("message");

    const brandIdInput = document.getElementById("brandId");
    const brandNameInput = document.getElementById("brandName");
    const brandSlugInput = document.getElementById("brandSlug");
    const brandCountryInput = document.getElementById("brandCountry");
    const brandLogoUrlInput = document.getElementById("brandLogoUrl");
    const brandLogoFileInput = document.getElementById("brandLogoFile");
    const logoPreviewWrap = document.getElementById("logoPreviewWrap");
    const logoPreview = document.getElementById("logoPreview");
    const brandSortOrderInput = document.getElementById("brandSortOrder");
    const brandIsActiveInput = document.getElementById("brandIsActive");

    const searchInput = document.getElementById("searchInput");
    const statusFilter = document.getElementById("statusFilter");

    const loading = document.getElementById("loading");
    const errorBox = document.getElementById("errorBox");
    const emptyBox = document.getElementById("emptyBox");
    const brandsWrap = document.getElementById("brandsWrap");
    const brandsTable = document.getElementById("brandsTable");

    const totalBrands = document.getElementById("totalBrands");
    const activeBrands = document.getElementById("activeBrands");
    const hiddenBrands = document.getElementById("hiddenBrands");

    let allBrands = [];

    async function checkAdminSession() {
      const { data } = await supabase.auth.getSession();

      if (!data.session) {
        window.location.href = "/admin/login/";
        return false;
      }

      return true;
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function slugify(text) {
      return text
        .toString()
        .toLowerCase()
        .trim()
        .replace(/&/g, "and")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
    }

    function numberOrZero(value) {
      const number = Number(value);
      return Number.isFinite(number) ? number : 0;
    }

    function sanitizeFileName(fileName) {
      return String(fileName || "logo")
        .toLowerCase()
        .replace(/[^a-z0-9._-]+/g, "-")
        .replace(/-+/g, "-")
        .replace(/^-|-$/g, "");
    }

    async function uploadBrandLogo(slug, file) {
      if (!file) return null;

      const maxSize = 5 * 1024 * 1024;
      if (file.size > maxSize) {
        throw new Error("فایل لوگو خیلی بزرگ است. حداکثر ۵ مگابایت.");
      }

      const allowedTypes = [
        "image/png",
        "image/svg+xml",
        "image/webp",
        "image/jpeg",
      ];
      if (!allowedTypes.includes(file.type)) {
        throw new Error("فقط PNG، SVG، WebP یا JPG مجاز است.");
      }

      const safeName = sanitizeFileName(file.name);
      const filePath = `brand-logos/${slug || "brand"}/${Date.now()}-${safeName}`;

      const { error: uploadError } = await supabase.storage
        .from("site-images")
        .upload(filePath, file, { cacheControl: "3600", upsert: false });

      if (uploadError) throw uploadError;

      const { data } = supabase.storage.from("site-images").getPublicUrl(filePath);
      return data.publicUrl;
    }

    function showLogoPreview(src) {
      if (src) {
        logoPreview.src = src;
        logoPreviewWrap.classList.remove("hidden");
      } else {
        logoPreview.removeAttribute("src");
        logoPreviewWrap.classList.add("hidden");
      }
    }

    function showMessage(text, type = "error") {
      message.textContent = text;
      message.classList.remove(
        "hidden",
        "bg-red-500/20",
        "text-red-200",
        "bg-green-500/20",
        "text-green-200"
      );

      if (type === "success") {
        message.classList.add("bg-green-500/20", "text-green-200");
      } else {
        message.classList.add("bg-red-500/20", "text-red-200");
      }
    }

    function resetForm() {
      brandForm.reset();
      brandIdInput.value = "";
      brandSortOrderInput.value = "0";
      brandIsActiveInput.value = "true";
      formTitle.textContent = "Add Brand";
      saveButton.textContent = "Save Brand";
      resetButton.classList.add("hidden");
      message.classList.add("hidden");

      if (brandLogoFileInput) brandLogoFileInput.value = "";
      showLogoPreview("");
    }

    function setFormForEdit(brand) {
      brandIdInput.value = brand.id;
      brandNameInput.value = brand.name || "";
      brandSlugInput.value = brand.slug || "";
      brandCountryInput.value = brand.country || "";
      brandLogoUrlInput.value = brand.logo_url || "";
      brandSortOrderInput.value = brand.sort_order ?? 0;
      brandIsActiveInput.value = brand.is_active ? "true" : "false";

      if (brandLogoFileInput) brandLogoFileInput.value = "";
      showLogoPreview(brand.logo_url || "");

      formTitle.textContent = "Edit Brand";
      saveButton.textContent = "Update Brand";
      resetButton.classList.remove("hidden");

      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function statusBadge(isActive) {
      const base = "inline-flex rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide";

      if (isActive) {
        return `<span class="${base} bg-green-500/20 text-green-200">Active</span>`;
      }

      return `<span class="${base} bg-red-500/20 text-red-200">Hidden</span>`;
    }

    function updateSummary() {
      totalBrands.textContent = String(allBrands.length);
      activeBrands.textContent = String(allBrands.filter((brand) => brand.is_active).length);
      hiddenBrands.textContent = String(allBrands.filter((brand) => !brand.is_active).length);
    }

    function getFilteredBrands() {
      const search = searchInput.value.trim().toLowerCase();
      const status = statusFilter.value;

      return allBrands.filter((brand) => {
        const searchable = [brand.name, brand.slug, brand.country]
          .join(" ")
          .toLowerCase();

        const matchesSearch = !search || searchable.includes(search);

        const matchesStatus =
          status === "all" ||
          (status === "active" && brand.is_active) ||
          (status === "hidden" && !brand.is_active);

        return matchesSearch && matchesStatus;
      });
    }

    function renderBrands() {
      updateSummary();

      const filteredBrands = getFilteredBrands();

      if (filteredBrands.length === 0) {
        brandsWrap.classList.add("hidden");
        emptyBox.classList.remove("hidden");
        return;
      }

      emptyBox.classList.add("hidden");
      brandsWrap.classList.remove("hidden");

      brandsTable.innerHTML = filteredBrands
        .map((brand) => {
          const nextActive = brand.is_active ? "false" : "true";

          return `
            <tr class="hover:bg-white/5">
              <td class="px-5 py-5">
                <div class="flex items-center gap-4">
                  <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-950 text-sm font-black text-amber-300">
                    ${
                      brand.logo_url
                        ? `<img src="${escapeHtml(brand.logo_url)}" alt="${escapeHtml(brand.name)}" class="h-full w-full rounded-2xl object-contain bg-white p-2" />`
                        : escapeHtml(String(brand.name || "?").slice(0, 2).toUpperCase())
                    }
                  </div>

                  <div>
                    <p class="font-black text-white">${escapeHtml(brand.name)}</p>
                    <p class="mt-1 text-xs font-semibold text-slate-500">${escapeHtml(brand.slug)}</p>
                  </div>
                </div>
              </td>

              <td class="px-5 py-5">
                <span class="font-bold text-slate-300">${escapeHtml(brand.country || "-")}</span>
              </td>

              <td class="px-5 py-5">
                <span class="font-black text-slate-300">${brand.sort_order ?? 0}</span>
              </td>

              <td class="px-5 py-5">
                ${statusBadge(brand.is_active)}
              </td>

              <td class="px-5 py-5 text-right">
                <div class="flex justify-end gap-2">
                  <button
                    data-action="edit"
                    data-id="${brand.id}"
                    class="rounded-xl bg-amber-400 px-4 py-2 text-xs font-black text-slate-950 transition hover:bg-amber-300"
                  >
                    Edit
                  </button>

                  <button
                    data-action="toggle-active"
                    data-id="${brand.id}"
                    data-active="${nextActive}"
                    class="rounded-xl bg-white/10 px-4 py-2 text-xs font-black text-white transition hover:bg-white/15"
                  >
                    ${brand.is_active ? "Hide" : "Activate"}
                  </button>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
    }

    async function loadBrands() {
      const allowed = await checkAdminSession();

      if (!allowed) return;

      const { data, error } = await supabase
        .from("brands")
        .select("*")
        .order("sort_order", { ascending: true })
        .order("name", { ascending: true });

      loading.classList.add("hidden");

      if (error) {
        errorBox.textContent = error.message;
        errorBox.classList.remove("hidden");
        return;
      }

      allBrands = data || [];
      renderBrands();
    }

    async function saveBrand(event) {
      event.preventDefault();

      saveButton.textContent = "Saving...";
      saveButton.disabled = true;

      try {
        const brandId = brandIdInput.value;
        const name = brandNameInput.value.trim();
        const slug = brandSlugInput.value.trim() || slugify(name);

        if (!name || !slug) {
          throw new Error("Brand name and slug are required.");
        }

        // If a logo file was selected, upload it and use its public URL.
        let logoUrl = brandLogoUrlInput.value.trim() || null;
        const logoFile = brandLogoFileInput?.files?.[0];
        if (logoFile) {
          saveButton.textContent = "Uploading logo...";
          logoUrl = await uploadBrandLogo(slug, logoFile);
          brandLogoUrlInput.value = logoUrl;
        }

        const payload = {
          name,
          slug,
          country: brandCountryInput.value.trim() || null,
          logo_url: logoUrl,
          sort_order: numberOrZero(brandSortOrderInput.value),
          is_active: brandIsActiveInput.value === "true",
        };

        // If not editing, but a brand with the same name/slug already exists,
        // update that one instead of inserting a duplicate (avoids unique-key error).
        let targetId = brandId;
        if (!targetId) {
          const existing = allBrands.find(
            (b) =>
              String(b.name).toLowerCase() === name.toLowerCase() ||
              String(b.slug).toLowerCase() === slug.toLowerCase()
          );
          if (existing) targetId = existing.id;
        }

        if (targetId) {
          const { error } = await supabase
            .from("brands")
            .update(payload)
            .eq("id", targetId);

          if (error) throw new Error(error.message);

          showMessage("Brand updated successfully ✅", "success");
        } else {
          const { error } = await supabase
            .from("brands")
            .insert(payload);

          if (error) throw new Error(error.message);

          showMessage("Brand added successfully ✅", "success");
        }

        await loadBrands();

        setTimeout(() => {
          resetForm();
        }, 600);
      } catch (error) {
        showMessage(error.message || "Something went wrong.");
      } finally {
        saveButton.disabled = false;
        saveButton.textContent = brandIdInput.value ? "Update Brand" : "Save Brand";
      }
    }

    async function toggleBrandActive(id, isActive) {
      const { error } = await supabase
        .from("brands")
        .update({ is_active: isActive })
        .eq("id", id);

      if (error) {
        alert(error.message);
        return;
      }

      allBrands = allBrands.map((brand) =>
        brand.id === id ? { ...brand, is_active: isActive } : brand
      );

      renderBrands();
    }

    brandsTable.addEventListener("click", async (event) => {
      const button = event.target.closest("button[data-action]");
      if (!button) return;

      const action = button.dataset.action;
      const id = button.dataset.id;

      if (action === "edit") {
        const brand = allBrands.find((item) => item.id === id);
        if (brand) setFormForEdit(brand);
      }

      if (action === "toggle-active") {
        await toggleBrandActive(id, button.dataset.active === "true");
      }
    });

    brandNameInput.addEventListener("input", () => {
      if (!brandIdInput.value) {
        brandSlugInput.value = slugify(brandNameInput.value);
      }
    });

    [searchInput, statusFilter].forEach((element) => {
      element.addEventListener("input", renderBrands);
      element.addEventListener("change", renderBrands);
    });

    brandLogoFileInput?.addEventListener("change", () => {
      const file = brandLogoFileInput.files?.[0];
      if (file) {
        showLogoPreview(URL.createObjectURL(file));
      } else {
        showLogoPreview(brandLogoUrlInput.value.trim() || "");
      }
    });

    resetButton.addEventListener("click", resetForm);
    brandForm.addEventListener("submit", saveBrand);

    loadBrands();
  </script>
</AdminLayout>
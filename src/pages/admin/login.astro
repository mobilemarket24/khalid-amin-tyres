---
import "../../styles/global.css";
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Admin Login | Khalid Amin Tyres">
  <main class="flex min-h-screen items-center justify-center px-5 py-12">
    <div class="w-full max-w-md rounded-[2rem] border border-white/10 bg-white/10 p-8 shadow-2xl backdrop-blur">
      <div class="text-center">
        <p class="text-sm font-black uppercase tracking-[0.25em] text-amber-300">
          Khalid Amin Tyres
        </p>

        <h1 class="mt-3 text-4xl font-black">
          Admin Login
        </h1>

        <p class="mt-3 text-sm font-semibold leading-7 text-slate-400">
          Login to manage tyres, rims, brands and website products.
        </p>
      </div>

      <form id="loginForm" class="mt-8 space-y-4">
        <div>
          <label class="mb-2 block text-sm font-black text-slate-300">
            Email
          </label>
          <input
            id="email"
            type="email"
            required
            class="w-full rounded-2xl border border-white/10 bg-slate-950 px-5 py-4 text-white outline-none ring-amber-300/40 transition focus:ring-4"
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label class="mb-2 block text-sm font-black text-slate-300">
            Password
          </label>
          <input
            id="password"
            type="password"
            required
            class="w-full rounded-2xl border border-white/10 bg-slate-950 px-5 py-4 text-white outline-none ring-amber-300/40 transition focus:ring-4"
            placeholder="Password"
          />
        </div>

        <div id="message" class="hidden rounded-2xl p-4 text-sm font-bold"></div>

        <button
          id="loginButton"
          type="submit"
          class="w-full rounded-2xl bg-amber-400 px-6 py-4 font-black text-slate-950 transition hover:bg-amber-300"
        >
          Login
        </button>
      </form>
    </div>
  </main>

  <script>
    import { supabase } from "../../lib/supabase";

    const form = document.getElementById("loginForm");
    const emailInput = document.getElementById("email");
    const passwordInput = document.getElementById("password");
    const message = document.getElementById("message");
    const loginButton = document.getElementById("loginButton");

    function showMessage(text, type = "error") {
      message.textContent = text;
      message.classList.remove("hidden", "bg-red-500/20", "text-red-200", "bg-green-500/20", "text-green-200");

      if (type === "success") {
        message.classList.add("bg-green-500/20", "text-green-200");
      } else {
        message.classList.add("bg-red-500/20", "text-red-200");
      }
    }

    async function checkSession() {
      const { data } = await supabase.auth.getSession();

      if (data.session) {
        window.location.href = "/admin/dashboard/";
      }
    }

    checkSession();

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      loginButton.textContent = "Logging in...";
      loginButton.disabled = true;

      const email = emailInput.value.trim();
      const password = passwordInput.value;

      const { error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        showMessage(error.message);
        loginButton.textContent = "Login";
        loginButton.disabled = false;
        return;
      }

      showMessage("Login successful. Redirecting...", "success");

      setTimeout(() => {
        window.location.href = "/admin/dashboard/";
      }, 700);
    });
  </script>
</AdminLayout>
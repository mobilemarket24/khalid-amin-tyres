---
import "../../styles/global.css";
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminShell from "../../components/admin/AdminShell.astro";
---

<AdminLayout title="Dashboard | Khalid Amin Tyres Admin">
  <AdminShell title="Dashboard" eyebrow="Daily Business Control" current="dashboard">
    <div class="space-y-6">
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
        <div class="rounded-[1.5rem] border border-white/10 bg-white/10 p-5">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">
            New Leads Today
          </p>
          <p id="todayLeadsCount" class="mt-3 text-4xl font-black text-amber-200">0</p>
          <p class="mt-2 text-xs font-semibold text-slate-500">
            Website form requests
          </p>
        </div>

        <div class="rounded-[1.5rem] border border-white/10 bg-amber-500/10 p-5">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-amber-300">
            New Leads
          </p>
          <p id="newLeadsCount" class="mt-3 text-4xl font-black text-amber-200">0</p>
          <p class="mt-2 text-xs font-semibold text-slate-500">
            Need first contact
          </p>
        </div>

        <div class="rounded-[1.5rem] border border-white/10 bg-red-500/10 p-5">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-red-300">
            Follow Up
          </p>
          <p id="followUpCount" class="mt-3 text-4xl font-black text-red-200">0</p>
          <p class="mt-2 text-xs font-semibold text-slate-500">
            Must be followed
          </p>
        </div>

        <div class="rounded-[1.5rem] border border-white/10 bg-green-500/10 p-5">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-green-300">
            Active Products
          </p>
          <p id="activeProductsCount" class="mt-3 text-4xl font-black text-green-200">0</p>
          <p class="mt-2 text-xs font-semibold text-slate-500">
            Visible products
          </p>
        </div>

        <div class="rounded-[1.5rem] border border-white/10 bg-purple-500/10 p-5">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-purple-300">
            Featured
          </p>
          <p id="featuredProductsCount" class="mt-3 text-4xl font-black text-purple-200">0</p>
          <p class="mt-2 text-xs font-semibold text-slate-500">
            Homepage products
          </p>
        </div>
      </div>

      <div class="grid gap-6 xl:grid-cols-[1.25fr_0.75fr]">
        <div class="rounded-[2rem] border border-white/10 bg-white/10 p-6">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.2em] text-amber-300">
                Recent Leads
              </p>
              <h3 class="mt-2 text-2xl font-black">
                Latest customer requests
              </h3>
            </div>

            <a
              href="/admin/leads/"
              class="rounded-2xl bg-amber-400 px-5 py-3 text-center text-sm font-black text-slate-950 transition hover:bg-amber-300"
            >
              Open Leads
            </a>
          </div>

          <div id="recentLeadsLoading" class="mt-6 rounded-2xl bg-slate-950/60 p-6 text-center font-black">
            Loading recent leads...
          </div>

          <div id="recentLeadsEmpty" class="mt-6 hidden rounded-2xl bg-slate-950/60 p-6 text-center">
            <h4 class="text-xl font-black">No leads yet</h4>
            <p class="mt-2 text-sm font-semibold text-slate-400">
              When customers submit the website form, they will appear here.
            </p>
          </div>

          <div id="recentLeadsList" class="mt-6 hidden space-y-4"></div>
        </div>

        <div class="space-y-6">
          <div class="rounded-[2rem] border border-white/10 bg-white/10 p-6">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-red-300">
              Quick Actions
            </p>

            <div class="mt-5 grid gap-3">
              <a
                href="/admin/products/new/"
                class="rounded-2xl bg-amber-400 px-5 py-4 text-center font-black text-slate-950 transition hover:bg-amber-300"
              >
                Add New Product
              </a>

              <a
                href="/admin/products/"
                class="rounded-2xl bg-white/10 px-5 py-4 text-center font-black text-white transition hover:bg-white/15"
              >
                Manage Products
              </a>

              <a
                href="/admin/brands/"
                class="rounded-2xl bg-white/10 px-5 py-4 text-center font-black text-white transition hover:bg-white/15"
              >
                Manage Brands
              </a>

              <a
                href="/admin/branches/"
                class="rounded-2xl bg-white/10 px-5 py-4 text-center font-black text-white transition hover:bg-white/15"
              >
                Manage Branches
              </a>

              <a
                href="/"
                target="_blank"
                class="rounded-2xl bg-red-500 px-5 py-4 text-center font-black text-white transition hover:bg-red-400"
              >
                View Website
              </a>
            </div>
          </div>

          <div class="rounded-[2rem] border border-white/10 bg-white/10 p-6">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-green-300">
              Sales Workflow
            </p>

            <div class="mt-5 space-y-4">
              <div class="rounded-2xl bg-slate-950/60 p-4">
                <p class="font-black text-amber-200">1. New</p>
                <p class="mt-1 text-sm font-semibold text-slate-400">
                  New website request. Contact customer fast.
                </p>
              </div>

              <div class="rounded-2xl bg-slate-950/60 p-4">
                <p class="font-black text-red-200">2. Quoted</p>
                <p class="mt-1 text-sm font-semibold text-slate-400">
                  Price sent. Add note and follow up.
                </p>
              </div>

              <div class="rounded-2xl bg-slate-950/60 p-4">
                <p class="font-black text-green-200">3. Won</p>
                <p class="mt-1 text-sm font-semibold text-slate-400">
                  Customer bought. Mark as won.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-[2rem] border border-white/10 bg-white/10 p-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-xs font-black uppercase tracking-[0.2em] text-purple-300">
              Product Requests
            </p>
            <h3 class="mt-2 text-2xl font-black">
              Leads with product interest
            </h3>
          </div>

          <a
            href="/admin/products/"
            class="rounded-2xl bg-white/10 px-5 py-3 text-center text-sm font-black text-white transition hover:bg-white/15"
          >
            Products
          </a>
        </div>

        <div id="productRequestsEmpty" class="mt-6 hidden rounded-2xl bg-slate-950/60 p-6 text-center">
          <p class="font-black text-slate-300">
            No product-specific requests yet.
          </p>
        </div>

        <div id="productRequestsList" class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3"></div>
      </div>
    </div>
  </AdminShell>

  <script>
    import { supabase } from "../../lib/supabase";

    const todayLeadsCount = document.getElementById("todayLeadsCount");
    const newLeadsCount = document.getElementById("newLeadsCount");
    const followUpCount = document.getElementById("followUpCount");
    const activeProductsCount = document.getElementById("activeProductsCount");
    const featuredProductsCount = document.getElementById("featuredProductsCount");

    const recentLeadsLoading = document.getElementById("recentLeadsLoading");
    const recentLeadsEmpty = document.getElementById("recentLeadsEmpty");
    const recentLeadsList = document.getElementById("recentLeadsList");

    const productRequestsEmpty = document.getElementById("productRequestsEmpty");
    const productRequestsList = document.getElementById("productRequestsList");

    let recentLeads = [];

    async function checkAdminSession() {
      const { data } = await supabase.auth.getSession();

      if (!data.session) {
        window.location.href = "/admin/login/";
        return false;
      }

      return true;
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function formatDate(value) {
      if (!value) return "-";

      try {
        return new Intl.DateTimeFormat("en-AE", {
          month: "short",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
        }).format(new Date(value));
      } catch {
        return value;
      }
    }

    function cleanPhone(value) {
      return String(value || "").replace(/\D/g, "");
    }

    function whatsappLink(lead) {
      const number = cleanPhone(lead.whatsapp || lead.phone || "");

      if (!number) return "";

      const productName = lead.products?.title || lead.product_title_snapshot || "";
      const size = lead.tyre_size || lead.rim_size || "";
      const messageParts = [
        "Hi, this is Khalid Amin Tyres.",
        productName ? `About: ${productName}` : "",
        size ? `Size: ${size}` : "",
        "How can we help you?",
      ].filter(Boolean);

      return `https://wa.me/${number}?text=${encodeURIComponent(messageParts.join("\n"))}`;
    }

    function statusBadge(status) {
      const base = "inline-flex rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide";

      if (status === "new") return `<span class="${base} bg-amber-500/20 text-amber-200">New</span>`;
      if (status === "contacted") return `<span class="${base} bg-blue-500/20 text-blue-200">Contacted</span>`;
      if (status === "quoted") return `<span class="${base} bg-purple-500/20 text-purple-200">Quoted</span>`;
      if (status === "follow_up") return `<span class="${base} bg-red-500/20 text-red-200">Follow Up</span>`;
      if (status === "won") return `<span class="${base} bg-green-500/20 text-green-200">Won</span>`;
      if (status === "lost") return `<span class="${base} bg-red-500/20 text-red-200">Lost</span>`;

      return `<span class="${base} bg-slate-500/20 text-slate-300">${escapeHtml(status)}</span>`;
    }

    function priorityBadge(priority) {
      const base = "inline-flex rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide";

      if (priority === "urgent") return `<span class="${base} bg-red-500/20 text-red-200">Urgent</span>`;
      if (priority === "high") return `<span class="${base} bg-red-500/20 text-red-200">High</span>`;
      if (priority === "normal") return `<span class="${base} bg-slate-500/20 text-slate-300">Normal</span>`;
      if (priority === "low") return `<span class="${base} bg-white/10 text-slate-400">Low</span>`;

      return `<span class="${base} bg-slate-500/20 text-slate-300">${escapeHtml(priority)}</span>`;
    }

    function getBranchLabel(lead) {
      const city = lead.branches?.city || "";

      if (city) return city;
      if (lead.branch_id === "dubai") return "Dubai";
      if (lead.branch_id === "sharjah") return "Sharjah";

      return "-";
    }

    function getRequestTitle(lead) {
      const product = lead.products?.title || lead.product_title_snapshot;

      if (product) return product;

      if (lead.tyre_size) return `Tyre Size: ${lead.tyre_size}`;
      if (lead.rim_size) return `Rim Size: ${lead.rim_size}`;

      const car = [lead.car_year, lead.car_make, lead.car_model].filter(Boolean).join(" ");
      if (car) return car;

      return lead.message || "General request";
    }

    function renderRecentLeads() {
      recentLeadsLoading.classList.add("hidden");

      if (!recentLeads.length) {
        recentLeadsEmpty.classList.remove("hidden");
        recentLeadsList.classList.add("hidden");
        return;
      }

      recentLeadsEmpty.classList.add("hidden");
      recentLeadsList.classList.remove("hidden");

      recentLeadsList.innerHTML = recentLeads
        .map((lead) => {
          const wa = whatsappLink(lead);
          const phone = lead.phone || lead.whatsapp || "-";

          return `
            <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/60 p-5">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div>
                  <div class="flex flex-wrap gap-2">
                    ${statusBadge(lead.status)}
                    ${priorityBadge(lead.priority)}
                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-black uppercase tracking-wide text-slate-300">
                      ${escapeHtml(getBranchLabel(lead))}
                    </span>
                  </div>

                  <h4 class="mt-4 text-lg font-black text-white">
                    ${escapeHtml(lead.customer_name || "No Name")}
                  </h4>

                  <p class="mt-1 text-sm font-bold text-slate-400">
                    ${escapeHtml(phone)}
                  </p>

                  <p class="mt-3 max-w-2xl text-sm font-semibold leading-6 text-slate-300">
                    ${escapeHtml(getRequestTitle(lead))}
                  </p>

                  <p class="mt-2 text-xs font-semibold text-slate-500">
                    ${escapeHtml(formatDate(lead.created_at))}
                  </p>
                </div>

                <div class="flex flex-wrap gap-2 lg:justify-end">
                  ${
                    wa
                      ? `<a href="${wa}" target="_blank" class="rounded-xl bg-green-500 px-4 py-3 text-xs font-black text-white transition hover:bg-green-400">WhatsApp</a>`
                      : ""
                  }

                  <select
                    data-action="status"
                    data-id="${lead.id}"
                    class="rounded-xl border border-white/10 bg-slate-950 px-4 py-3 text-xs font-black text-white outline-none"
                  >
                    <option value="new" ${lead.status === "new" ? "selected" : ""}>New</option>
                    <option value="contacted" ${lead.status === "contacted" ? "selected" : ""}>Contacted</option>
                    <option value="quoted" ${lead.status === "quoted" ? "selected" : ""}>Quoted</option>
                    <option value="follow_up" ${lead.status === "follow_up" ? "selected" : ""}>Follow Up</option>
                    <option value="won" ${lead.status === "won" ? "selected" : ""}>Won</option>
                    <option value="lost" ${lead.status === "lost" ? "selected" : ""}>Lost</option>
                  </select>
                </div>
              </div>
            </article>
          `;
        })
        .join("");
    }

    function renderProductRequests() {
      const productLeads = recentLeads
        .filter((lead) => lead.products?.title || lead.product_title_snapshot)
        .slice(0, 6);

      if (!productLeads.length) {
        productRequestsEmpty.classList.remove("hidden");
        productRequestsList.innerHTML = "";
        return;
      }

      productRequestsEmpty.classList.add("hidden");

      productRequestsList.innerHTML = productLeads
        .map((lead) => {
          const wa = whatsappLink(lead);
          const productTitle = lead.products?.title || lead.product_title_snapshot || "Product request";

          return `
            <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/60 p-5">
              <div class="flex flex-wrap gap-2">
                ${statusBadge(lead.status)}
                <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-black uppercase tracking-wide text-slate-300">
                  ${escapeHtml(getBranchLabel(lead))}
                </span>
              </div>

              <h4 class="mt-4 line-clamp-2 text-lg font-black text-white">
                ${escapeHtml(productTitle)}
              </h4>

              <p class="mt-3 text-sm font-bold text-slate-400">
                ${escapeHtml(lead.phone || lead.whatsapp || "-")}
              </p>

              <p class="mt-2 text-xs font-semibold text-slate-500">
                ${escapeHtml(formatDate(lead.created_at))}
              </p>

              ${
                wa
                  ? `<a href="${wa}" target="_blank" class="mt-4 inline-flex rounded-xl bg-green-500 px-4 py-3 text-xs font-black text-white transition hover:bg-green-400">WhatsApp Customer</a>`
                  : ""
              }
            </article>
          `;
        })
        .join("");
    }

    async function loadCount(query) {
      const { count, error } = await query;

      if (error) {
        return 0;
      }

      return count || 0;
    }

    async function loadDashboardCounts() {
      const todayStart = new Date();
      todayStart.setHours(0, 0, 0, 0);

      const [
        todayLeads,
        newLeads,
        followUps,
        activeProducts,
        featuredProducts,
      ] = await Promise.all([
        loadCount(
          supabase
            .from("leads")
            .select("id", { count: "exact", head: true })
            .gte("created_at", todayStart.toISOString())
        ),
        loadCount(
          supabase
            .from("leads")
            .select("id", { count: "exact", head: true })
            .eq("status", "new")
        ),
        loadCount(
          supabase
            .from("leads")
            .select("id", { count: "exact", head: true })
            .eq("status", "follow_up")
        ),
        loadCount(
          supabase
            .from("products")
            .select("id", { count: "exact", head: true })
            .eq("status", "active")
        ),
        loadCount(
          supabase
            .from("products")
            .select("id", { count: "exact", head: true })
            .eq("status", "active")
            .eq("featured", true)
        ),
      ]);

      todayLeadsCount.textContent = String(todayLeads);
      newLeadsCount.textContent = String(newLeads);
      followUpCount.textContent = String(followUps);
      activeProductsCount.textContent = String(activeProducts);
      featuredProductsCount.textContent = String(featuredProducts);
    }

    async function loadRecentLeads() {
      const { data, error } = await supabase
        .from("leads")
        .select(`
          *,
          branches (
            id,
            name,
            city
          ),
          products (
            id,
            title,
            product_type,
            size_display
          )
        `)
        .order("created_at", { ascending: false })
        .limit(10);

      if (error) {
        recentLeadsLoading.textContent = error.message;
        return;
      }

      recentLeads = data || [];
      renderRecentLeads();
      renderProductRequests();
    }

    async function updateLeadStatus(id, status) {
      const { error } = await supabase
        .from("leads")
        .update({ status })
        .eq("id", id);

      if (error) {
        alert(error.message);
        return;
      }

      recentLeads = recentLeads.map((lead) =>
        lead.id === id ? { ...lead, status } : lead
      );

      renderRecentLeads();
      renderProductRequests();
      await loadDashboardCounts();
    }

    recentLeadsList.addEventListener("change", async (event) => {
      const select = event.target.closest("select[data-action='status']");
      if (!select) return;

      await updateLeadStatus(select.dataset.id, select.value);
    });

    async function initDashboard() {
      const allowed = await checkAdminSession();

      if (!allowed) return;

      await Promise.all([
        loadDashboardCounts(),
        loadRecentLeads(),
      ]);
    }

    initDashboard();
  </script>
</AdminLayout>
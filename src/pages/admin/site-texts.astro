---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminShell from "../../components/admin/AdminShell.astro";
---

<AdminLayout title="Site Texts | Admin Panel">
  <AdminShell current="site-texts">
    <main class="min-h-screen bg-[#0a0a0e] px-4 py-6 text-white sm:px-6 lg:px-8">
      <section class="mx-auto max-w-7xl">
        <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-sm font-black uppercase tracking-[0.25em] text-amber-300">
              Website Content Manager
            </p>

            <h1 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">
              Site Texts
            </h1>

            <p class="mt-3 max-w-3xl text-sm font-semibold leading-7 text-slate-400">
              Manage website titles, subtitles, header texts, footer texts, hero texts, services texts, branches texts, FAQ texts, SEO page texts, SEO meta titles and CTA content from one control panel.
            </p>
          </div>

          <button
            id="addTextBtn"
            type="button"
            class="rounded-2xl bg-amber-400 px-6 py-4 text-sm font-black text-slate-950 transition hover:bg-amber-300"
          >
            Add New Text
          </button>
        </div>

        <div id="statusBox" class="mb-6 hidden rounded-2xl border px-5 py-4 text-sm font-bold"></div>

        <div class="mb-6 grid gap-4 md:grid-cols-4">
          <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 backdrop-blur-xl">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">Total Texts</p>
            <p id="totalTexts" class="mt-2 text-3xl font-black text-white">0</p>
          </div>

          <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 backdrop-blur-xl">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">Active</p>
            <p id="activeTexts" class="mt-2 text-3xl font-black text-amber-300">0</p>
          </div>

          <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 backdrop-blur-xl">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">English</p>
            <p id="englishTexts" class="mt-2 text-3xl font-black text-emerald-300">0</p>
          </div>

          <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 backdrop-blur-xl">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">Arabic</p>
            <p id="arabicTexts" class="mt-2 text-3xl font-black text-red-300">0</p>
          </div>
        </div>

        <div class="mb-6 rounded-[1.5rem] border border-white/10 bg-white/5 p-4 backdrop-blur-xl">
          <div class="grid gap-4 lg:grid-cols-[1fr_180px_220px_180px]">
            <input
              id="searchInput"
              type="search"
              placeholder="Search by key, title, text, page..."
              class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none placeholder:text-slate-500 focus:border-amber-400"
            />

            <select
              id="languageFilter"
              class="rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-bold text-white outline-none focus:border-amber-400"
            >
              <option value="all">All Languages</option>
              <option value="en">English</option>
              <option value="ar">Arabic</option>
            </select>

            <select
              id="groupFilter"
              class="rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-bold text-white outline-none focus:border-amber-400"
            >
              <option value="all">All Groups</option>
              <option value="home_hero">Home Hero</option>
              <option value="header">Header</option>
              <option value="footer">Footer</option>
              <option value="services">Services</option>
              <option value="branches">Branches</option>
              <option value="faq">FAQ</option>
              <option value="seo_pages">SEO Pages</option>
              <option value="seo_meta">SEO Meta</option>
              <option value="final_cta">Final CTA</option>
              <option value="general">General</option>
            </select>

            <select
              id="statusFilter"
              class="rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-bold text-white outline-none focus:border-amber-400"
            >
              <option value="all">All Status</option>
              <option value="active">Active</option>
              <option value="hidden">Hidden</option>
            </select>
          </div>
        </div>

        <div id="loadingBox" class="rounded-[2rem] border border-white/10 bg-white/5 p-8 text-center backdrop-blur-xl">
          <p class="text-sm font-bold text-slate-300">Loading site texts...</p>
        </div>

        <div id="textsGrid" class="grid gap-6 xl:grid-cols-2"></div>
      </section>
    </main>

    <div id="addModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 px-4 backdrop-blur-sm">
      <div class="w-full max-w-2xl rounded-[2rem] border border-white/10 bg-[#0e0e12] p-6 text-white shadow-2xl">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-2xl font-black">Add New Site Text</h2>
            <p class="mt-2 text-sm font-semibold text-slate-400">
              Create a new text key for future website sections.
            </p>
          </div>

          <button
            id="closeModalBtn"
            type="button"
            class="rounded-xl bg-white/10 px-4 py-2 text-sm font-black text-white hover:bg-white/15"
          >
            Close
          </button>
        </div>

        <form id="addTextForm" class="mt-6 grid gap-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                Text Key
              </label>
              <input
                name="text_key"
                required
                placeholder="example_key"
                class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
              />
            </div>

            <div>
              <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                Title
              </label>
              <input
                name="title"
                required
                placeholder="Example Title"
                class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                Group
              </label>
              <input
                name="group_key"
                value="general"
                class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
              />
            </div>

            <div>
              <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                Language
              </label>
              <select
                name="language"
                class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-bold text-white outline-none focus:border-amber-400"
              >
                <option value="en">English</option>
                <option value="ar">Arabic</option>
              </select>
            </div>

            <div>
              <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                Type
              </label>
              <select
                name="content_type"
                class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-bold text-white outline-none focus:border-amber-400"
              >
                <option value="text">Text</option>
                <option value="textarea">Textarea</option>
              </select>
            </div>
          </div>

          <div>
            <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
              Text Value
            </label>
            <textarea
              name="text_value"
              rows="4"
              required
              class="w-full resize-none rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
            ></textarea>
          </div>

          <div>
            <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
              Description
            </label>
            <textarea
              name="description"
              rows="3"
              class="w-full resize-none rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
            ></textarea>
          </div>

          <div>
            <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
              Page Path
            </label>
            <input
              name="page_path"
              placeholder="/"
              class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
            />
          </div>

          <button
            type="submit"
            class="rounded-2xl bg-amber-400 px-6 py-4 text-sm font-black text-slate-950 hover:bg-amber-300"
          >
            Create Text
          </button>
        </form>
      </div>
    </div>

    <script>
      import { supabase } from "../../lib/supabase";

      let siteTexts = [];

      const loadingBox = document.getElementById("loadingBox");
      const textsGrid = document.getElementById("textsGrid");
      const statusBox = document.getElementById("statusBox");

      const searchInput = document.getElementById("searchInput");
      const languageFilter = document.getElementById("languageFilter");
      const groupFilter = document.getElementById("groupFilter");
      const statusFilter = document.getElementById("statusFilter");

      const totalTexts = document.getElementById("totalTexts");
      const activeTexts = document.getElementById("activeTexts");
      const englishTexts = document.getElementById("englishTexts");
      const arabicTexts = document.getElementById("arabicTexts");

      const addModal = document.getElementById("addModal");
      const addTextBtn = document.getElementById("addTextBtn");
      const closeModalBtn = document.getElementById("closeModalBtn");
      const addTextForm = document.getElementById("addTextForm");

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function showStatus(message, type = "success") {
        statusBox.textContent = message;
        statusBox.classList.remove(
          "hidden",
          "border-emerald-400/30",
          "bg-emerald-400/10",
          "text-emerald-200",
          "border-red-400/30",
          "bg-red-400/10",
          "text-red-200",
          "border-amber-400/30",
          "bg-amber-400/10",
          "text-amber-200"
        );

        if (type === "error") {
          statusBox.classList.add("border-red-400/30", "bg-red-400/10", "text-red-200");
        } else if (type === "info") {
          statusBox.classList.add("border-amber-400/30", "bg-amber-400/10", "text-amber-200");
        } else {
          statusBox.classList.add("border-emerald-400/30", "bg-emerald-400/10", "text-emerald-200");
        }

        setTimeout(() => {
          statusBox.classList.add("hidden");
        }, 4500);
      }

      function getGroupLabel(groupKey) {
        const labels = {
          home_hero: "Home Hero",
          header: "Header",
          footer: "Footer",
          services: "Services",
          branches: "Branches",
          faq: "FAQ",
          seo_pages: "SEO Pages",
          seo_meta: "SEO Meta",
          final_cta: "Final CTA",
          general: "General",
        };

        return labels[groupKey] || groupKey || "General";
      }

      function getGroupBadge(groupKey) {
        const colors = {
          home_hero: "bg-amber-400 text-slate-950",
          header: "bg-pink-400 text-slate-950",
          footer: "bg-indigo-400 text-slate-950",
          services: "bg-emerald-400 text-slate-950",
          branches: "bg-blue-400 text-slate-950",
          faq: "bg-yellow-400 text-slate-950",
          seo_pages: "bg-purple-500 text-white",
          seo_meta: "bg-lime-400 text-slate-950",
          final_cta: "bg-red-500 text-white",
          general: "bg-slate-600 text-white",
        };

        return `<span class="rounded-full px-3 py-1 text-[11px] font-black uppercase tracking-[0.16em] ${colors[groupKey] || colors.general}">
          ${escapeHtml(getGroupLabel(groupKey))}
        </span>`;
      }

      function getLanguageBadge(language) {
        if (language === "ar") {
          return `<span class="rounded-full bg-emerald-400 px-3 py-1 text-[11px] font-black uppercase tracking-[0.16em] text-slate-950">Arabic</span>`;
        }

        return `<span class="rounded-full bg-amber-400 px-3 py-1 text-[11px] font-black uppercase tracking-[0.16em] text-slate-950">English</span>`;
      }

      function updateStats(items) {
        totalTexts.textContent = String(items.length);
        activeTexts.textContent = String(items.filter((item) => item.is_active).length);
        englishTexts.textContent = String(items.filter((item) => item.language === "en").length);
        arabicTexts.textContent = String(items.filter((item) => item.language === "ar").length);
      }

      function renderTexts() {
        const query = String(searchInput.value || "").toLowerCase().trim();
        const language = languageFilter.value;
        const group = groupFilter.value;
        const status = statusFilter.value;

        const filtered = siteTexts.filter((item) => {
          const searchable = [
            item.text_key,
            item.group_key,
            item.language,
            item.title,
            item.text_value,
            item.description,
            item.page_path,
            item.content_type,
          ]
            .join(" ")
            .toLowerCase();

          const matchesSearch = !query || searchable.includes(query);
          const matchesLanguage = language === "all" || item.language === language;
          const matchesGroup = group === "all" || item.group_key === group;
          const matchesStatus =
            status === "all" ||
            (status === "active" && item.is_active) ||
            (status === "hidden" && !item.is_active);

          return matchesSearch && matchesLanguage && matchesGroup && matchesStatus;
        });

        updateStats(siteTexts);

        if (!filtered.length) {
          textsGrid.innerHTML = `
            <div class="xl:col-span-2 rounded-[2rem] border border-white/10 bg-white/5 p-8 text-center">
              <p class="text-sm font-bold text-slate-300">No texts found for this filter.</p>
            </div>
          `;
          return;
        }

        textsGrid.innerHTML = filtered
          .map((item) => {
            const groupBadge = getGroupBadge(item.group_key);
            const languageBadge = getLanguageBadge(item.language);

            const activeBadge = item.is_active
              ? `<span class="rounded-full bg-emerald-400/15 px-3 py-1 text-[11px] font-black uppercase tracking-[0.16em] text-emerald-200">Active</span>`
              : `<span class="rounded-full bg-red-400/15 px-3 py-1 text-[11px] font-black uppercase tracking-[0.16em] text-red-200">Hidden</span>`;

            const fieldHtml =
              item.content_type === "textarea"
                ? `
                  <textarea
                    name="text_value"
                    rows="5"
                    class="w-full resize-none rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold leading-7 text-white outline-none focus:border-amber-400"
                  >${escapeHtml(item.text_value || "")}</textarea>
                `
                : `
                  <input
                    name="text_value"
                    value="${escapeHtml(item.text_value || "")}"
                    class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
                  />
                `;

            return `
              <article class="rounded-[2rem] border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
                <div class="flex flex-wrap gap-2">
                  ${groupBadge}
                  ${languageBadge}
                  ${activeBadge}
                </div>

                <div class="mt-5">
                  <p class="text-xs font-black uppercase tracking-[0.2em] text-amber-300">
                    ${escapeHtml(item.text_key)}
                  </p>

                  <h2 class="mt-2 text-2xl font-black text-white">
                    ${escapeHtml(item.title || item.text_key)}
                  </h2>

                  <p class="mt-2 text-sm font-semibold leading-6 text-slate-400">
                    ${escapeHtml(item.description || "No description.")}
                  </p>
                </div>

                <form class="site-text-form mt-5 grid gap-4" data-text-id="${escapeHtml(item.id)}">
                  <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                      <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                        Title
                      </label>
                      <input
                        name="title"
                        value="${escapeHtml(item.title || "")}"
                        class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
                      />
                    </div>

                    <div>
                      <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                        Page Path
                      </label>
                      <input
                        name="page_path"
                        value="${escapeHtml(item.page_path || "")}"
                        class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
                      />
                    </div>
                  </div>

                  <div class="grid gap-4 sm:grid-cols-3">
                    <div>
                      <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                        Group
                      </label>
                      <input
                        name="group_key"
                        value="${escapeHtml(item.group_key || "general")}"
                        class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold text-white outline-none focus:border-amber-400"
                      />
                    </div>

                    <div>
                      <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                        Language
                      </label>
                      <select
                        name="language"
                        class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-bold text-white outline-none focus:border-amber-400"
                      >
                        <option value="en" ${item.language === "en" ? "selected" : ""}>English</option>
                        <option value="ar" ${item.language === "ar" ? "selected" : ""}>Arabic</option>
                      </select>
                    </div>

                    <div>
                      <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                        Field Type
                      </label>
                      <select
                        name="content_type"
                        class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-bold text-white outline-none focus:border-amber-400"
                      >
                        <option value="text" ${item.content_type === "text" ? "selected" : ""}>Text</option>
                        <option value="textarea" ${item.content_type === "textarea" ? "selected" : ""}>Textarea</option>
                      </select>
                    </div>
                  </div>

                  <div>
                    <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                      Website Text
                    </label>
                    ${fieldHtml}
                  </div>

                  <div>
                    <label class="mb-2 block text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                      Description
                    </label>
                    <textarea
                      name="description"
                      rows="3"
                      class="w-full resize-none rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm font-semibold leading-7 text-white outline-none focus:border-amber-400"
                    >${escapeHtml(item.description || "")}</textarea>
                  </div>

                  <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3">
                    <input
                      name="is_active"
                      type="checkbox"
                      ${item.is_active ? "checked" : ""}
                      class="h-5 w-5 accent-amber-400"
                    />
                    <span class="text-sm font-black text-white">Active</span>
                  </div>

                  <div class="grid gap-3 sm:grid-cols-4">
                    <button
                      type="submit"
                      class="rounded-2xl bg-amber-400 px-5 py-4 text-sm font-black text-slate-950 transition hover:bg-amber-300"
                    >
                      Save Changes
                    </button>

                    <a
                      href="${escapeHtml(item.page_path || "/")}"
                      target="_blank"
                      class="rounded-2xl bg-white/10 px-5 py-4 text-center text-sm font-black text-white transition hover:bg-white/15"
                    >
                      Preview Page
                    </a>

                    <button
                      type="button"
                      data-copy-key="${escapeHtml(item.text_key)}"
                      class="rounded-2xl bg-white/10 px-5 py-4 text-sm font-black text-white transition hover:bg-white/15"
                    >
                      Copy Key
                    </button>

                    <button
                      type="button"
                      data-delete-id="${escapeHtml(item.id)}"
                      class="rounded-2xl bg-red-500/15 px-5 py-4 text-sm font-black text-red-200 transition hover:bg-red-500/25"
                    >
                      Delete
                    </button>
                  </div>
                </form>
              </article>
            `;
          })
          .join("");
      }

      async function checkAdminSession() {
        const { data } = await supabase.auth.getSession();

        if (!data.session) {
          window.location.href = "/admin/login/";
          return false;
        }

        return true;
      }

      async function loadTexts() {
        const isLoggedIn = await checkAdminSession();
        if (!isLoggedIn) return;

        loadingBox.classList.remove("hidden");
        textsGrid.innerHTML = "";

        const { data, error } = await supabase
          .from("site_texts")
          .select("*")
          .order("sort_order", { ascending: true })
          .order("created_at", { ascending: true });

        loadingBox.classList.add("hidden");

        if (error) {
          showStatus(error.message || "Could not load site texts.", "error");
          return;
        }

        siteTexts = data || [];
        renderTexts();
      }

      async function handleFormSubmit(event) {
        event.preventDefault();

        const form = event.target.closest(".site-text-form");
        if (!form) return;

        const textId = form.dataset.textId;
        const formData = new FormData(form);

        const submitButton = form.querySelector('button[type="submit"]');
        const originalText = submitButton.textContent;

        try {
          submitButton.textContent = "Saving...";
          submitButton.disabled = true;

          const updatePayload = {
            title: String(formData.get("title") || "").trim(),
            group_key: String(formData.get("group_key") || "general").trim(),
            language: String(formData.get("language") || "en").trim(),
            text_value: String(formData.get("text_value") || "").trim(),
            description: String(formData.get("description") || "").trim(),
            page_path: String(formData.get("page_path") || "").trim(),
            content_type: String(formData.get("content_type") || "text").trim(),
            is_active: formData.get("is_active") === "on",
          };

          const { error } = await supabase
            .from("site_texts")
            .update(updatePayload)
            .eq("id", textId);

          if (error) throw error;

          showStatus("Site text updated successfully.");
          await loadTexts();
        } catch (error) {
          showStatus(error.message || "Could not update site text.", "error");
        } finally {
          submitButton.textContent = originalText;
          submitButton.disabled = false;
        }
      }

      async function handleAddText(event) {
        event.preventDefault();

        const formData = new FormData(addTextForm);

        const payload = {
          text_key: String(formData.get("text_key") || "").trim(),
          title: String(formData.get("title") || "").trim(),
          group_key: String(formData.get("group_key") || "general").trim(),
          language: String(formData.get("language") || "en").trim(),
          text_value: String(formData.get("text_value") || "").trim(),
          description: String(formData.get("description") || "").trim(),
          page_path: String(formData.get("page_path") || "").trim(),
          content_type: String(formData.get("content_type") || "text").trim(),
          is_active: true,
          sort_order: 999,
        };

        if (!payload.text_key || !payload.title || !payload.text_value) {
          showStatus("Text key, title and text value are required.", "error");
          return;
        }

        const { error } = await supabase.from("site_texts").insert(payload);

        if (error) {
          showStatus(error.message || "Could not create site text.", "error");
          return;
        }

        addTextForm.reset();
        addModal.classList.add("hidden");
        addModal.classList.remove("flex");

        showStatus("New site text created successfully.");
        await loadTexts();
      }

      async function handleDeleteText(event) {
        const button = event.target.closest("[data-delete-id]");
        if (!button) return;

        const textId = button.dataset.deleteId;
        const confirmed = window.confirm("Are you sure you want to delete this text?");

        if (!confirmed) return;

        const { error } = await supabase.from("site_texts").delete().eq("id", textId);

        if (error) {
          showStatus(error.message || "Could not delete site text.", "error");
          return;
        }

        showStatus("Site text deleted successfully.");
        await loadTexts();
      }

      async function handleCopyKey(event) {
        const button = event.target.closest("[data-copy-key]");
        if (!button) return;

        const key = button.dataset.copyKey;
        await navigator.clipboard.writeText(key);
        showStatus(`Copied text key: ${key}`, "info");
      }

      searchInput.addEventListener("input", renderTexts);
      languageFilter.addEventListener("change", renderTexts);
      groupFilter.addEventListener("change", renderTexts);
      statusFilter.addEventListener("change", renderTexts);

      addTextBtn.addEventListener("click", () => {
        addModal.classList.remove("hidden");
        addModal.classList.add("flex");
      });

      closeModalBtn.addEventListener("click", () => {
        addModal.classList.add("hidden");
        addModal.classList.remove("flex");
      });

      addTextForm.addEventListener("submit", handleAddText);

      document.addEventListener("submit", (event) => {
        if (event.target.closest(".site-text-form")) {
          handleFormSubmit(event);
        }
      });

      document.addEventListener("click", (event) => {
        if (event.target.closest("[data-copy-key]")) {
          handleCopyKey(event);
        }

        if (event.target.closest("[data-delete-id]")) {
          handleDeleteText(event);
        }
      });

      loadTexts();
    </script>
  </AdminShell>
</AdminLayout>
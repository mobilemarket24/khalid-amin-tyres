---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SeoPageHero from "../../components/SeoPageHero.astro";
import FeaturedProductsSection from "../../components/FeaturedProductsSection.astro";
import LeadCaptureSection from "../../components/LeadCaptureSection.astro";
import BranchesSection from "../../components/BranchesSection.astro";
import FAQSection from "../../components/FAQSection.astro";
import FinalCtaSection from "../../components/FinalCtaSection.astro";
import { getBrandsByCategory } from "../../lib/brands";

export async function getStaticPaths() {
  const makes = await getBrandsByCategory("rim");
  return makes.map((make) => ({
    params: { brand: make.slug },
    props: { makeName: make.name, makeSlug: make.slug },
  }));
}

const { makeName } = Astro.props;

const title = `${makeName} Rims & Alloy Wheels in Dubai & Sharjah | Khalid Amin Tyres`;
const description = `Buy ${makeName} rims and alloy wheels in Dubai and Sharjah. Khalid Amin Tyres offers the right rim sizes and fitment for your ${makeName} with fast WhatsApp pricing.`;
---

<BaseLayout title={title} description={description}>
  <main>
    <SeoPageHero
      imageKey="rims_dubai_hero"
      badge={`${makeName} Rims`}
      title={`${makeName} Rims & Alloy Wheels`}
      subtitle={`Looking for rims for your ${makeName}? Get the correct sizes, fitment support and availability from Khalid Amin Tyres in Dubai and Sharjah.`}
      branch="dubai"
      bullets={[
        `Rims that fit your ${makeName}`,
        "Alloy wheel sizes",
        "Fitment support",
        "Fast WhatsApp pricing",
      ]}
    />

    <FeaturedProductsSection
      productType="rim"
      featuredOnly={false}
      limit={24}
      badge={`${makeName} Rims`}
      title={`Rims & alloy wheels for ${makeName}`}
      subtitle={`Browse rim and alloy wheel options suitable for ${makeName}, then get today's price on WhatsApp from your nearest branch.`}
      emptyText={`No ${makeName} rims are listed online right now. Message us on WhatsApp for current ${makeName} rim sizes and pricing.`}
    />

    <LeadCaptureSection />
    <BranchesSection />
    <FAQSection />
    <FinalCtaSection />
  </main>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SeoPageHero from "../../components/SeoPageHero.astro";
import FeaturedProductsSection from "../../components/FeaturedProductsSection.astro";
import LeadCaptureSection from "../../components/LeadCaptureSection.astro";
import BranchesSection from "../../components/BranchesSection.astro";
import FAQSection from "../../components/FAQSection.astro";
import FinalCtaSection from "../../components/FinalCtaSection.astro";
import { getActiveBrands } from "../../lib/brands";

export async function getStaticPaths() {
  const brands = await getActiveBrands();
  return brands.map((brand) => ({
    params: { brand: brand.slug },
    props: { brandName: brand.name, brandSlug: brand.slug },
  }));
}

const { brandName, brandSlug } = Astro.props;

const title = `${brandName} Rims & Alloy Wheels in Dubai & Sharjah | Khalid Amin Tyres`;
const description = `Shop ${brandName} rims and alloy wheels in Dubai and Sharjah. Khalid Amin Tyres offers ${brandName} rims with fitment support and fast WhatsApp pricing across both branches.`;
---

<BaseLayout title={title} description={description}>
  <main>
    <SeoPageHero
      imageKey="rims_dubai_hero"
      badge={`${brandName} Rims`}
      title={`${brandName} Rims & Alloy Wheels`}
      subtitle={`Looking for ${brandName} rims? Get sizes, fitment support and availability from Khalid Amin Tyres in Dubai and Sharjah.`}
      branch="dubai"
      bullets={[
        `Genuine ${brandName} rims`,
        "Alloy wheel sizes",
        "Fitment support",
        "Fast WhatsApp pricing",
      ]}
    />

    <FeaturedProductsSection
      productType="rim"
      brand={brandSlug}
      featuredOnly={false}
      limit={24}
      badge={`${brandName} Rims`}
      title={`Available ${brandName} rims & alloy wheels`}
      subtitle={`Browse ${brandName} rim options with size and fitment details, then get today's price on WhatsApp from your nearest branch.`}
      emptyText={`No ${brandName} rims are listed online right now. Message us on WhatsApp for current ${brandName} stock and pricing.`}
    />

    <LeadCaptureSection />
    <BranchesSection />
    <FAQSection />
    <FinalCtaSection />
  </main>
</BaseLayout>

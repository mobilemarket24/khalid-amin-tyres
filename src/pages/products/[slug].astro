---
import { createClient } from "@supabase/supabase-js";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BranchesSection from "../../components/BranchesSection.astro";
import FinalCtaSection from "../../components/FinalCtaSection.astro";

const SITE_URL = "https://khalidamintyres.com";

const PRODUCT_SELECT = `
  id, title, slug, sku, product_type, status, model,
  short_description, description, size_display, origin,
  price, price_aed, price_visible,
  warranty_text, warranty_months, manufacture_year, tire_year,
  vehicle_type, season, run_flat,
  load_index, speed_rating, tire_load_index, tire_speed_rating,
  rim_diameter, rim_width, rim_pcd, rim_offset, rim_center_bore, rim_finish,
  seo_title, meta_description, whatsapp_message,
  brands ( name, slug, logo_url ),
  product_images ( image_url, alt_text, is_primary, sort_order ),
  product_branch_availability ( branch_id, availability_status, quantity )
`;

export async function getStaticPaths() {
  const url = import.meta.env.PUBLIC_SUPABASE_URL;
  const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  if (!url || !key) return [];

  const supabase = createClient(url, key, {
    auth: { persistSession: false, autoRefreshToken: false, detectSessionInUrl: false },
  });

  const { data, error } = await supabase
    .from("products")
    .select(`
      id, title, slug, sku, product_type, status, model,
      short_description, description, size_display, origin,
      price, price_aed, price_visible,
      warranty_text, warranty_months, manufacture_year, tire_year,
      vehicle_type, season, run_flat,
      load_index, speed_rating, tire_load_index, tire_speed_rating,
      rim_diameter, rim_width, rim_pcd, rim_offset, rim_center_bore, rim_finish,
      seo_title, meta_description, whatsapp_message,
      brands ( name, slug, logo_url ),
      product_images ( image_url, alt_text, is_primary, sort_order ),
      product_branch_availability ( branch_id, availability_status, quantity )
    `)
    .eq("status", "active");

  if (error || !data) return [];

  return data
    .filter((p) => p.slug)
    .map((product) => ({
      params: { slug: product.slug },
      props: { product },
    }));
}

const { product } = Astro.props;

// --- normalize fields (schema has some duplicate/legacy columns) ---
const brand = product.brands || null;
const brandName = brand?.name || "";

const images = (product.product_images || [])
  .slice()
  .sort((a, b) => {
    if (a.is_primary && !b.is_primary) return -1;
    if (!a.is_primary && b.is_primary) return 1;
    return (a.sort_order ?? 0) - (b.sort_order ?? 0);
  });
const primaryImage = images[0]?.image_url || "/images/hero-banner.png";
const primaryAlt =
  images[0]?.alt_text ||
  [brandName, product.title, product.size_display].filter(Boolean).join(" ");

const priceValue = Number(product.price ?? product.price_aed);
const hasPrice =
  product.price_visible !== false && Number.isFinite(priceValue) && priceValue > 0;
const priceLabel = hasPrice ? `AED ${priceValue.toLocaleString("en-AE")}` : "";
const setOfFour = hasPrice ? `AED ${(priceValue * 4).toLocaleString("en-AE")}` : "";

const loadIndex = product.load_index || product.tire_load_index || "";
const speedRating = product.speed_rating || product.tire_speed_rating || "";
const year = product.manufacture_year || product.tire_year || "";
const warranty =
  product.warranty_text ||
  (product.warranty_months ? `${product.warranty_months} months warranty` : "");

const isRim = product.product_type === "rim";

const specs = (
  isRim
    ? [
        ["Size", product.size_display],
        ["Brand", brandName],
        ["Model", product.model],
        ["Diameter", product.rim_diameter ? `${product.rim_diameter}"` : ""],
        ["Width", product.rim_width ? `${product.rim_width}"` : ""],
        ["PCD", product.rim_pcd],
        ["Offset", product.rim_offset],
        ["Center Bore", product.rim_center_bore],
        ["Finish", product.rim_finish],
        ["Origin", product.origin],
      ]
    : [
        ["Size", product.size_display],
        ["Brand", brandName],
        ["Model", product.model],
        ["Load Index", loadIndex],
        ["Speed Rating", speedRating],
        ["Run Flat", product.run_flat ? "Yes" : ""],
        ["Vehicle Type", product.vehicle_type],
        ["Usage", product.season],
        ["Year", year],
        ["Origin", product.origin],
      ]
).filter(([, value]) => value);

// --- availability per branch ---
const branchMeta = {
  sharjah: { label: "Sharjah", phone: "971503512023" },
  dubai: { label: "Dubai", phone: "971561615010" },
};

function availabilityFor(branchId) {
  const row = (product.product_branch_availability || []).find(
    (r) => r.branch_id === branchId
  );
  return row?.availability_status || "unknown";
}

function availabilityText(status) {
  if (status === "in_stock") return "In Stock";
  if (status === "limited") return "Limited";
  if (status === "order_only") return "Order Only";
  if (status === "out_of_stock") return "Out of Stock";
  return "Ask Us";
}

function availabilityClass(status) {
  if (status === "in_stock") return "bg-green-100 text-green-700";
  if (status === "limited") return "bg-amber-100 text-amber-700";
  if (status === "order_only") return "bg-blue-100 text-blue-700";
  if (status === "out_of_stock") return "bg-red-100 text-red-600";
  return "bg-slate-100 text-slate-500";
}

function whatsAppUrl(branchId) {
  const meta = branchMeta[branchId];
  const lines = [
    product.whatsapp_message ||
      "Hi, I need price and availability for this product:",
    product.title,
    product.size_display ? `Size: ${product.size_display}` : "",
    brandName ? `Brand: ${brandName}` : "",
    year ? `Year: ${year}` : "",
    `Branch: ${meta.label}`,
    `Page: ${SITE_URL}/products/${product.slug}/`,
  ].filter(Boolean);
  return `https://wa.me/${meta.phone}?text=${encodeURIComponent(lines.join("\n"))}`;
}

const branchBlocks = [
  { id: "sharjah", status: availabilityFor("sharjah") },
  { id: "dubai", status: availabilityFor("dubai") },
];

const anyInStock = branchBlocks.some((b) =>
  ["in_stock", "limited", "order_only"].includes(b.status)
);

// --- SEO ---
const pageTitle =
  product.seo_title ||
  [brandName, product.title, product.size_display, "| Khalid Amin Tyres"]
    .filter(Boolean)
    .join(" ");
const pageDescription =
  product.meta_description ||
  product.short_description ||
  `${[brandName, product.title].filter(Boolean).join(" ")} available at Khalid Amin Tyres in Dubai and Sharjah. Get today's price and availability on WhatsApp.`;

const canonical = `${SITE_URL}/products/${product.slug}/`;
const typeLabel = isRim ? "Rims" : "Tyres";
const brandHref = brand?.slug ? `/${isRim ? "rims" : "tyres"}/${brand.slug}/` : null;

// --- JSON-LD (Product + Breadcrumb) ---
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: [brandName, product.title].filter(Boolean).join(" "),
  description: pageDescription,
  image: images.length ? images.map((i) => i.image_url) : [`${SITE_URL}/og-image.jpg`],
  sku: product.sku || undefined,
  mpn: product.model || undefined,
  category: typeLabel,
  brand: brandName ? { "@type": "Brand", name: brandName } : undefined,
  offers: {
    "@type": "Offer",
    url: canonical,
    priceCurrency: "AED",
    ...(hasPrice ? { price: priceValue } : {}),
    availability: anyInStock
      ? "https://schema.org/InStock"
      : "https://schema.org/OutOfStock",
    seller: { "@id": `${SITE_URL}/#organization` },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${SITE_URL}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: typeLabel,
      item: `${SITE_URL}/${isRim ? "rims" : "tyres"}-dubai/`,
    },
    ...(brandName && brandHref
      ? [{ "@type": "ListItem", position: 3, name: brandName, item: `${SITE_URL}${brandHref}` }]
      : []),
    {
      "@type": "ListItem",
      position: brandName && brandHref ? 4 : 3,
      name: product.title,
      item: canonical,
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} image={primaryImage}>
  <main class="bg-[#0a0a0e] text-slate-100">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mx-auto max-w-7xl px-5 pt-8 sm:px-8 lg:px-12">
      <ol class="flex flex-wrap items-center gap-2 text-xs font-bold text-slate-400">
        <li><a href="/" class="hover:text-amber-300">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href={`/${isRim ? "rims" : "tyres"}-dubai/`} class="hover:text-amber-300">{typeLabel}</a></li>
        {brandName && brandHref && (
          <>
            <li aria-hidden="true">/</li>
            <li><a href={brandHref} class="hover:text-amber-300">{brandName}</a></li>
          </>
        )}
        <li aria-hidden="true">/</li>
        <li class="text-slate-200">{product.title}</li>
      </ol>
    </nav>

    <section class="mx-auto grid max-w-7xl gap-10 px-5 py-10 sm:px-8 lg:grid-cols-2 lg:px-12 lg:py-14">
      <!-- GALLERY -->
      <div>
        <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-white p-6">
          <img
            id="productMainImage"
            src={primaryImage}
            alt={primaryAlt}
            loading="eager"
            class="mx-auto h-[360px] w-full object-contain sm:h-[440px]"
          />
        </div>

        {images.length > 1 && (
          <div class="mt-4 grid grid-cols-4 gap-3">
            {images.slice(0, 8).map((img, index) => (
              <button
                type="button"
                data-thumb={img.image_url}
                class={`thumb overflow-hidden rounded-2xl border bg-white p-2 transition ${
                  index === 0 ? "border-amber-400" : "border-white/10 hover:border-white/30"
                }`}
                aria-label={`View image ${index + 1}`}
              >
                <img src={img.image_url} alt={img.alt_text || primaryAlt} loading="lazy" class="h-16 w-full object-contain" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- INFO -->
      <div class="flex flex-col">
        <div class="flex items-center gap-3">
          {brand?.logo_url ? (
            <img src={brand.logo_url} alt={brandName} class="h-7 w-auto max-w-[130px] object-contain" loading="lazy" />
          ) : brandName ? (
            <span class="text-sm font-black uppercase tracking-[0.14em] text-amber-300">{brandName}</span>
          ) : null}
          <span class="rounded-full bg-amber-100 px-3 py-1 text-[10px] font-black uppercase tracking-[0.14em] text-amber-700">
            {product.product_type || "product"}
          </span>
        </div>

        <h1 class="mt-4 text-3xl font-black leading-tight sm:text-4xl">
          {brandName ? `${brandName} ` : ""}{product.title}
        </h1>

        {product.size_display && (
          <p class="mt-2 text-2xl font-black tracking-tight text-amber-300">{product.size_display}</p>
        )}

        {product.short_description && (
          <p class="mt-4 max-w-xl text-base font-semibold leading-7 text-slate-300">
            {product.short_description}
          </p>
        )}

        {hasPrice && (
          <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-5">
            <div class="flex items-baseline gap-3">
              <span class="text-3xl font-black text-white">{priceLabel}</span>
              <span class="text-xs font-bold text-slate-400">per {isRim ? "rim" : "tyre"}</span>
            </div>
            {!isRim && (
              <p class="mt-1 text-sm font-bold text-slate-400">Set of 4: {setOfFour}</p>
            )}
          </div>
        )}

        <!-- Branch availability + WhatsApp -->
        <div class="mt-6 grid gap-3">
          {branchBlocks.map((b) => (
            <a
              href={whatsAppUrl(b.id)}
              target="_blank"
              rel="noopener"
              class={`flex items-center justify-between gap-3 rounded-2xl px-5 py-4 font-black transition ${
                b.id === "dubai"
                  ? "bg-slate-900 text-white hover:bg-slate-800"
                  : "bg-amber-400 text-slate-950 hover:bg-amber-300"
              }`}
            >
              <span class="flex items-center gap-2 text-sm">
                <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.532 5.86L.054 23.454a.5.5 0 0 0 .492.546.499.499 0 0 0 .139-.02l5.789-1.534A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
                </svg>
                WhatsApp {branchMeta[b.id].label}
              </span>
              <span class={`rounded-full px-3 py-1 text-[11px] font-black ${availabilityClass(b.status)}`}>
                {availabilityText(b.status)}
              </span>
            </a>
          ))}
        </div>

        {warranty && (
          <p class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-slate-300">
            <svg class="h-4 w-4 text-blue-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
            {warranty}
          </p>
        )}
      </div>
    </section>

    <!-- SPECS + DESCRIPTION -->
    <section class="mx-auto max-w-7xl px-5 pb-14 sm:px-8 lg:px-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.9fr]">
        {product.description && (
          <div class="rounded-[2rem] border border-white/10 bg-white/5 p-7">
            <h2 class="text-xl font-black text-white">Product details</h2>
            <p class="mt-4 whitespace-pre-line text-sm font-semibold leading-7 text-slate-300">
              {product.description}
            </p>
          </div>
        )}

        {specs.length > 0 && (
          <div class="rounded-[2rem] border border-white/10 bg-white/5 p-7">
            <h2 class="text-xl font-black text-white">Specifications</h2>
            <dl class="mt-4 divide-y divide-white/10">
              {specs.map(([label, value]) => (
                <div class="flex items-center justify-between gap-4 py-3">
                  <dt class="text-xs font-black uppercase tracking-wide text-slate-500">{label}</dt>
                  <dd class="text-sm font-bold text-slate-200">{value}</dd>
                </div>
              ))}
              {product.sku && (
                <div class="flex items-center justify-between gap-4 py-3">
                  <dt class="text-xs font-black uppercase tracking-wide text-slate-500">SKU</dt>
                  <dd class="text-sm font-bold text-slate-200">{product.sku}</dd>
                </div>
              )}
            </dl>
          </div>
        )}
      </div>
    </section>

    <BranchesSection />
    <FinalCtaSection />
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <script>
    const main = document.getElementById("productMainImage");
    document.querySelectorAll(".thumb").forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = btn.getAttribute("data-thumb");
        if (src && main) main.setAttribute("src", src);
        document.querySelectorAll(".thumb").forEach((t) => {
          t.classList.remove("border-amber-400");
          t.classList.add("border-white/10");
        });
        btn.classList.remove("border-white/10");
        btn.classList.add("border-amber-400");
      });
    });
  </script>
</BaseLayout>

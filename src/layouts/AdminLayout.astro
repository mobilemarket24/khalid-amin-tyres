---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Admin Panel | Khalid Amin Tyres" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-[#0a0a0e] text-white antialiased">
    <slot />
  </body>
</html>
---
const isArabic = Astro.url.pathname.startsWith("/ar");

// icon keys map to the inline SVGs defined below
const items = isArabic
  ? [
      { value: "+50", label: "علامة تجارية", icon: "brands", accent: "amber" },
      { value: "2", label: "فرعان", icon: "branch", accent: "red" },
      { value: "دبي والشارقة", label: "تغطية", icon: "pin", accent: "amber" },
      { value: "واتساب", label: "رد سريع", icon: "chat", accent: "red" },
      { value: "نفس اليوم", label: "تركيب وميزان", icon: "bolt", accent: "amber" },
    ]
  : [
      { value: "50+", label: "Premium Brands", icon: "brands", accent: "amber" },
      { value: "2", label: "Branches", icon: "branch", accent: "red" },
      { value: "Dubai & Sharjah", label: "Coverage", icon: "pin", accent: "amber" },
      { value: "WhatsApp", label: "Fast Support", icon: "chat", accent: "red" },
      { value: "Same-Day", label: "Fitting Available", icon: "bolt", accent: "amber" },
    ];

const icons: Record<string, string> = {
  brands:
    'M11.48 3.5a.56.56 0 0 1 1.04 0l2.13 4.31 4.76.69a.56.56 0 0 1 .31.96l-3.44 3.36.81 4.74a.56.56 0 0 1-.81.59L12 16.3l-4.26 2.24a.56.56 0 0 1-.81-.59l.81-4.74-3.44-3.36a.56.56 0 0 1 .31-.96l4.76-.69 2.13-4.31z',
  branch:
    'M3 21V7l9-4 9 4v14M3 21h18M9 21v-6h6v6M7 11h.01M12 11h.01M17 11h.01',
  pin: 'M12 21s-7-5.33-7-11a7 7 0 1 1 14 0c0 5.67-7 11-7 11zM12 12a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z',
  chat: 'M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5z',
  bolt: 'M13 2 4.5 13.5H11l-1 8.5L19.5 10H13l0-8z',
};
---

<div class="relative border-y border-slate-200 bg-white" dir={isArabic ? "rtl" : "ltr"}>
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5">
      {
        items.map((item, i) => (
          <div
            class="group flex flex-col items-center justify-center gap-3 border-slate-100 px-4 py-8 text-center transition-colors hover:bg-slate-50 sm:border-r last:sm:border-r-0"
            data-animate
            data-animate-delay={String(i + 1)}
          >
            <span
              class={`flex h-12 w-12 items-center justify-center rounded-2xl transition-transform group-hover:-translate-y-0.5 ${
                item.accent === "amber"
                  ? "bg-amber-50 text-amber-600"
                  : "bg-red-50 text-red-500"
              }`}
            >
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={icons[item.icon]} />
              </svg>
            </span>

            <div>
              <div
                class={`text-lg font-black leading-tight sm:text-xl ${
                  item.accent === "amber" ? "text-slate-900" : "text-slate-900"
                }`}
              >
                {item.value}
              </div>
              <div class="mt-1 text-[10px] font-black uppercase tracking-[0.18em] text-slate-400">
                {item.label}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

---
const isArabic = Astro.url.pathname.startsWith("/ar");

const content = isArabic
  ? {
      badge: "كيف يعمل",
      title: "احصل على سعر الإطار أو الجنط في ٣ خطوات",
      subtitle: "العملية بسيطة وسريعة — اختر المقاس، تواصل معنا، واحصل على السعر اليوم.",
      steps: [
        {
          number: "01",
          title: "اختر المقاس",
          desc: "استخدم صندوق البحث أو اكتب مقاس الإطار أو الجنط أو موديل سيارتك.",
          icon: "search",
        },
        {
          number: "02",
          title: "تواصل عبر واتساب",
          desc: "أرسل طلبك مباشرة لفريق دبي أو الشارقة عبر واتساب بضغطة واحدة.",
          icon: "chat",
        },
        {
          number: "03",
          title: "احصل على السعر",
          desc: "يرد عليك الفريق بسرعة بالسعر والتوفر ووقت التركيب.",
          icon: "tag",
        },
      ],
    }
  : {
      badge: "How It Works",
      title: "Get your tyre or rim price in 3 simple steps",
      subtitle: "The process is fast and easy — pick your size, contact us, and get today's price on WhatsApp.",
      steps: [
        {
          number: "01",
          title: "Pick your size",
          desc: "Use the search tool or type your tyre size, rim size or car model.",
          icon: "search",
        },
        {
          number: "02",
          title: "WhatsApp us",
          desc: "Send your request directly to our Dubai or Sharjah team with one tap.",
          icon: "chat",
        },
        {
          number: "03",
          title: "Get your price",
          desc: "Our team replies fast with pricing, availability and fitting time.",
          icon: "tag",
        },
      ],
    };

const stepIcons: Record<string, string> = {
  search: "M21 21l-4.35-4.35M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16z",
  chat: "M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5z",
  tag: "M20.59 13.41 13.42 20.6a2 2 0 0 1-2.83 0L3 13V3h10l7.59 7.58a2 2 0 0 1 0 2.83zM7 7h.01",
};
---

<section
  class="relative overflow-hidden bg-slate-50 px-5 py-16 sm:px-8 lg:px-12"
  dir={isArabic ? "rtl" : "ltr"}
>
  <div class="relative mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center" data-animate>
      <span class="inline-flex rounded-full border border-amber-300 bg-amber-50 px-4 py-2 text-xs font-black uppercase tracking-[0.22em] text-amber-600">
        {content.badge}
      </span>

      <h2 class="mt-5 text-3xl font-black leading-tight text-slate-900 sm:text-4xl lg:text-5xl">
        {content.title}
      </h2>

      <p class="mt-4 text-base font-semibold leading-8 text-slate-500">
        {content.subtitle}
      </p>
    </div>

    <div class="relative mt-14">
      <div class="absolute left-[16.66%] right-[16.66%] top-10 hidden h-0.5 bg-gradient-to-r from-amber-200 via-amber-300 to-amber-200 lg:block"></div>

      <div class="grid gap-6 lg:grid-cols-3">
        {
          content.steps.map((step, i) => (
            <div
              data-animate
              data-animate-delay={String(i + 1)}
              class="group relative flex flex-col items-center rounded-[2rem] border border-slate-200 bg-white p-8 text-center shadow-sm transition duration-300 hover:-translate-y-1.5 hover:border-amber-300 hover:shadow-[0_25px_60px_-25px_rgba(245,158,11,0.45)]"
            >
              <span class="absolute right-5 top-5 text-4xl font-black text-slate-100 transition-colors group-hover:text-amber-100">
                {step.number}
              </span>

              <div class="relative flex h-20 w-20 items-center justify-center rounded-2xl bg-amber-400 text-slate-950 shadow-lg shadow-amber-400/30 transition-transform group-hover:scale-105">
                <svg
                  class="h-9 w-9"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={stepIcons[step.icon]} />
                </svg>

                <span class="absolute -right-2 -top-2 flex h-7 w-7 items-center justify-center rounded-full bg-slate-900 text-xs font-black text-white">
                  {i + 1}
                </span>
              </div>

              <h3 class="mt-6 text-xl font-black text-slate-900">{step.title}</h3>
              <p class="mt-3 text-sm font-semibold leading-7 text-slate-500">{step.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

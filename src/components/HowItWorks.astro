---
const isArabic = Astro.url.pathname.startsWith("/ar");

const content = isArabic
  ? {
      badge: "كيف يعمل",
      title: "احصل على سعر الإطار أو الجنط في ٣ خطوات",
      subtitle: "العملية بسيطة وسريعة — اختر المقاس، تواصل معنا، واحصل على السعر اليوم.",
      steps: [
        {
          number: "01",
          title: "اختر المقاس",
          desc: "استخدم صندوق البحث أو اكتب مقاس الإطار أو الجنط أو موديل سيارتك.",
          accent: "cyan",
        },
        {
          number: "02",
          title: "تواصل عبر واتساب",
          desc: "أرسل طلبك مباشرة لفريق دبي أو الشارقة عبر واتساب بضغطة واحدة.",
          accent: "orange",
        },
        {
          number: "03",
          title: "احصل على السعر",
          desc: "يرد عليك الفريق بسرعة بالسعر والتوفر ووقت التركيب.",
          accent: "cyan",
        },
      ],
    }
  : {
      badge: "How It Works",
      title: "Get your tyre or rim price in 3 simple steps",
      subtitle: "The process is fast and easy — pick your size, contact us, and get today's price on WhatsApp.",
      steps: [
        {
          number: "01",
          title: "Pick your size",
          desc: "Use the search tool or type your tyre size, rim size or car model.",
          accent: "cyan",
        },
        {
          number: "02",
          title: "WhatsApp us",
          desc: "Send your request directly to our Dubai or Sharjah team with one tap.",
          accent: "orange",
        },
        {
          number: "03",
          title: "Get your price",
          desc: "Our team replies fast with pricing, availability and fitting time.",
          accent: "cyan",
        },
      ],
    };
---

<section
  class="relative overflow-hidden bg-slate-50 px-5 py-16 sm:px-8 lg:px-12"
  dir={isArabic ? "rtl" : "ltr"}
>
  <div class="relative mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center" data-animate>
      <span class="inline-flex rounded-full border border-amber-300 bg-amber-50 px-4 py-2 text-xs font-black uppercase tracking-[0.22em] text-amber-600">
        {content.badge}
      </span>

      <h2 class="mt-5 text-3xl font-black leading-tight text-slate-900 sm:text-4xl lg:text-5xl">
        {content.title}
      </h2>

      <p class="mt-4 text-base font-semibold leading-8 text-slate-500">
        {content.subtitle}
      </p>
    </div>

    <div class="relative mt-14">
      <div class="absolute left-0 right-0 top-10 hidden h-px bg-gradient-to-r from-transparent via-slate-300 to-transparent lg:block"></div>

      <div class="grid gap-6 lg:grid-cols-3">
        {
          content.steps.map((step, i) => (
            <div
              data-animate
              data-animate-delay={String(i + 1)}
              class="relative flex flex-col items-center rounded-[2rem] border border-slate-200 bg-white p-7 text-center shadow-lg"
            >
              <div
                class={`relative flex h-20 w-20 items-center justify-center rounded-full border-2 text-2xl font-black ${
                  step.accent === "cyan"
                    ? "border-amber-300 bg-amber-50 text-amber-600"
                    : "border-red-200 bg-red-50 text-red-500"
                }`}
              >
                {step.number}
                <span
                  class={`absolute -right-1 -top-1 flex h-5 w-5 items-center justify-center rounded-full text-[10px] font-black ${
                    step.accent === "cyan"
                      ? "bg-amber-400 text-slate-950"
                      : "bg-red-500 text-white"
                  }`}
                >
                  {i + 1}
                </span>
              </div>

              <h3 class="mt-5 text-xl font-black text-slate-900">{step.title}</h3>
              <p class="mt-3 text-sm font-semibold leading-7 text-slate-500">{step.desc}</p>

              <div
                class={`mt-5 h-1 w-12 rounded-full ${
                  step.accent === "cyan" ? "bg-amber-400" : "bg-red-400"
                }`}
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

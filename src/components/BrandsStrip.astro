---
const isArabic = Astro.url.pathname.startsWith("/ar");

// Fallback style (color + short letters) used for the badge when a brand has no uploaded logo.
// Brands are loaded live from the Supabase `brands` table by the script below; this map only
// styles the no-logo badge for known names. Unknown brands fall back to a neutral badge.
interface BrandStyle {
  color: string;
  bg: string;
  short: string;
}

const brandStyles: Record<string, BrandStyle> = {
  michelin:    { color: "#0057A8", bg: "#E8F0FA", short: "M"  },
  bridgestone: { color: "#CC0000", bg: "#FAEAEA", short: "BS" },
  continental: { color: "#F5A200", bg: "#FEF6E6", short: "C"  },
  pirelli:     { color: "#1A1A1A", bg: "#F0F0F0", short: "P"  },
  goodyear:    { color: "#005BAC", bg: "#E6EFF8", short: "GY" },
  dunlop:      { color: "#006633", bg: "#E6F3EC", short: "D"  },
  yokohama:    { color: "#D40000", bg: "#FAEAEA", short: "Y"  },
  hankook:     { color: "#E30613", bg: "#FAEAEA", short: "H"  },
  toyo:        { color: "#CC0000", bg: "#FAEAEA", short: "T"  },
  falken:      { color: "#CC0000", bg: "#F0F0F0", short: "FK" },
  nitto:       { color: "#1A1A1A", bg: "#F0F0F0", short: "N"  },
  kumho:       { color: "#0061A1", bg: "#E6EFF8", short: "K"  },
  nexen:       { color: "#0056A2", bg: "#E6EFF8", short: "NX" },
  bfgoodrich:  { color: "#003087", bg: "#E6EFF8", short: "BF" },
  zeetex:      { color: "#0A6E3B", bg: "#E6F3EC", short: "Z"  },
  fortune:     { color: "#B8860B", bg: "#FBF3DF", short: "FO" },
  vitour:      { color: "#C8102E", bg: "#FAEAEA", short: "V"  },
};

// Initial server-rendered list (graceful fallback before the live data loads / if JS is off).
const initialBrands = Object.entries(brandStyles).map(([slug, style]) => ({
  name: slug.charAt(0).toUpperCase() + slug.slice(1),
  ...style,
}));
---

<div
  class="relative overflow-hidden border-y border-slate-200 bg-white py-10"
  data-animate
  data-brands-strip
>
  <div class="mx-auto max-w-7xl px-5 text-center">
    <p class="mb-8 text-[10px] font-black uppercase tracking-[0.35em] text-slate-400">
      {isArabic ? "العلامات التجارية المتوفرة" : "Brands We Carry"}
    </p>
  </div>

  <div class="relative overflow-hidden">
    <div
      class="flex animate-brand-scroll items-center gap-3 whitespace-nowrap"
      data-brands-track
    >
      {
        [...initialBrands, ...initialBrands].map((brand) => (
          <div class="inline-flex shrink-0 items-center gap-3 rounded-2xl border border-slate-100 bg-slate-50 px-5 py-3 shadow-sm transition-all duration-200 hover:border-slate-300 hover:bg-white hover:shadow-md">
            <div
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl text-xs font-black"
              style={`background:${brand.bg}; color:${brand.color};`}
            >
              {brand.short}
            </div>
            <span class="text-sm font-black tracking-tight" style={`color:${brand.color};`}>
              {brand.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  import { createClient } from "@supabase/supabase-js";

  // Badge styling for known brands when no logo is uploaded (mirrors the frontmatter map).
  const brandStyles = {
    michelin:    { color: "#0057A8", bg: "#E8F0FA", short: "M"  },
    bridgestone: { color: "#CC0000", bg: "#FAEAEA", short: "BS" },
    continental: { color: "#F5A200", bg: "#FEF6E6", short: "C"  },
    pirelli:     { color: "#1A1A1A", bg: "#F0F0F0", short: "P"  },
    goodyear:    { color: "#005BAC", bg: "#E6EFF8", short: "GY" },
    dunlop:      { color: "#006633", bg: "#E6F3EC", short: "D"  },
    yokohama:    { color: "#D40000", bg: "#FAEAEA", short: "Y"  },
    hankook:     { color: "#E30613", bg: "#FAEAEA", short: "H"  },
    toyo:        { color: "#CC0000", bg: "#FAEAEA", short: "T"  },
    falken:      { color: "#CC0000", bg: "#F0F0F0", short: "FK" },
    nitto:       { color: "#1A1A1A", bg: "#F0F0F0", short: "N"  },
    kumho:       { color: "#0061A1", bg: "#E6EFF8", short: "K"  },
    nexen:       { color: "#0056A2", bg: "#E6EFF8", short: "NX" },
    bfgoodrich:  { color: "#003087", bg: "#E6EFF8", short: "BF" },
    zeetex:      { color: "#0A6E3B", bg: "#E6F3EC", short: "Z"  },
    fortune:     { color: "#B8860B", bg: "#FBF3DF", short: "FO" },
    vitour:      { color: "#C8102E", bg: "#FAEAEA", short: "V"  },
  };

  const brandsSupabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    {
      auth: {
        persistSession: false,
        autoRefreshToken: false,
        detectSessionInUrl: false,
      },
    }
  );

  function escapeHtml(value) {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function styleFor(name) {
    const key = String(name || "").toLowerCase().replace(/[^a-z0-9]+/g, "");
    if (brandStyles[key]) return brandStyles[key];
    const short = String(name || "?")
      .replace(/[^A-Za-z0-9]+/g, "")
      .slice(0, 2)
      .toUpperCase();
    return { color: "#1A1A1A", bg: "#F0F0F0", short: short || "?" };
  }

  function pillHtml(brand) {
    const style = styleFor(brand.name);
    const name = escapeHtml(brand.name);

    const visual = brand.logo_url
      ? `<img src="${escapeHtml(brand.logo_url)}" alt="${name}"
            class="h-9 w-auto max-w-[120px] shrink-0 object-contain"
            loading="lazy"
            onerror="this.outerHTML='<div class=\\'flex h-9 w-9 shrink-0 items-center justify-center rounded-xl text-xs font-black\\' style=\\'background:${style.bg}; color:${style.color};\\'>${escapeHtml(style.short)}</div>'" />`
      : `<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl text-xs font-black"
            style="background:${style.bg}; color:${style.color};">${escapeHtml(style.short)}</div>`;

    return `
      <div class="inline-flex shrink-0 items-center gap-3 rounded-2xl border border-slate-100 bg-slate-50 px-5 py-3 shadow-sm transition-all duration-200 hover:border-slate-300 hover:bg-white hover:shadow-md">
        ${visual}
        <span class="text-sm font-black tracking-tight" style="color:${style.color};">${name}</span>
      </div>`;
  }

  async function loadBrands() {
    const track = document.querySelector("[data-brands-track]");
    if (!track) return;

    const { data, error } = await brandsSupabase
      .from("brands")
      .select("name, logo_url, sort_order, is_active")
      .eq("is_active", true)
      .order("sort_order", { ascending: true })
      .order("name", { ascending: true });

    if (error || !data || data.length === 0) return;

    const pills = data.map(pillHtml).join("");
    // Duplicate the set so the marquee scroll stays seamless.
    track.innerHTML = pills + pills;
  }

  loadBrands();
</script>

---
import { getSiteText } from "../lib/siteContent";

interface Props {
  textKey: string;
  fallback: string;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const {
  textKey,
  fallback,
  as = "span",
  class: className = "",
} = Astro.props;

const Tag = as;

// در زمان build از Supabase گرفته می‌شود (سمت سرور)، نه در مرورگر.
const value = await getSiteText(textKey, fallback);
---

<Tag class={className}>{value}</Tag>

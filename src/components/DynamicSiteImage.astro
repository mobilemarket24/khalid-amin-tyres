---
import { getSiteImage } from "../lib/siteContent";

interface Props {
  imageKey: string;
  fallbackSrc: string;
  alt: string;
  class?: string;
  loading?: "eager" | "lazy";
}

const {
  imageKey,
  fallbackSrc,
  alt,
  class: className = "",
  loading = "lazy",
} = Astro.props;

// در زمان build از Supabase گرفته می‌شود (سمت سرور)، نه در مرورگر.
const image = await getSiteImage(imageKey);
const src = image?.image_url || fallbackSrc;
const finalAlt = image?.alt_text || alt;
---

<img src={src} alt={finalAlt} class={className} loading={loading} />

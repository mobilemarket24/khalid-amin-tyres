---
interface Props {
  current?: string;
}

const { current = "dashboard" } = Astro.props;

const navItems = [
  { key: "dashboard", label: "Dashboard", href: "/admin/dashboard/" },
  { key: "products", label: "Products", href: "/admin/products/" },
  { key: "brands", label: "Brands", href: "/admin/brands/" },
  { key: "branches", label: "Branches", href: "/admin/branches/" },
  { key: "leads", label: "Leads", href: "/admin/leads/" },
  { key: "site-images", label: "Site Images", href: "/admin/site-images/" },
  { key: "site-texts", label: "Site Texts", href: "/admin/site-texts/" },
];
---

<div class="min-h-screen bg-[#0a0a0e] text-white">
  <aside class="fixed inset-y-0 left-0 z-40 hidden w-72 border-r border-white/10 bg-[#0e0e12]/95 p-5 backdrop-blur-xl lg:block">
    <a href="/admin/dashboard/" class="block rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
      <p class="text-xs font-black uppercase tracking-[0.25em] text-amber-300">
        Admin Panel
      </p>
      <h1 class="mt-2 text-2xl font-black leading-tight text-white">
        Khalid Amin Tyres
      </h1>
      <p class="mt-2 text-xs font-semibold text-slate-500">
        Website Control Center
      </p>
    </a>

    <nav class="mt-6 grid gap-2">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`rounded-2xl px-4 py-3 text-sm font-black transition ${
              current === item.key
                ? "bg-amber-400 text-slate-950"
                : "text-slate-300 hover:bg-white/10 hover:text-white"
            }`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <button
      id="adminPublishBtn"
      type="button"
      class="mt-5 w-full rounded-2xl bg-amber-400 px-4 py-3 text-sm font-black text-slate-950 transition hover:bg-amber-300"
    >
      🚀 Publish changes
    </button>
    <p id="adminPublishStatus" class="mt-2 hidden text-center text-xs font-bold"></p>

    <button
      id="adminLogoutBtn"
      type="button"
      class="absolute bottom-5 left-5 right-5 rounded-2xl bg-red-500/15 px-4 py-3 text-sm font-black text-red-200 transition hover:bg-red-500/25"
    >
      Logout
    </button>
  </aside>

  <header class="sticky top-0 z-30 border-b border-white/10 bg-[#0e0e12]/95 px-4 py-4 backdrop-blur-xl lg:hidden">
    <div class="flex items-center justify-between gap-4">
      <a href="/admin/dashboard/" class="font-black text-white">
        Khalid Amin Admin
      </a>

      <div class="flex items-center gap-2">
        <button
          id="adminPublishBtnMobile"
          type="button"
          class="rounded-xl bg-amber-400 px-3 py-2 text-sm font-black text-slate-950 transition hover:bg-amber-300"
        >
          🚀 Publish
        </button>

        <select
          id="mobileAdminNav"
          class="rounded-xl border border-white/10 bg-slate-950 px-3 py-2 text-sm font-bold text-white"
        >
          {
            navItems.map((item) => (
              <option value={item.href} selected={current === item.key}>
                {item.label}
              </option>
            ))
          }
        </select>
      </div>
    </div>
  </header>

  <div class="lg:pl-72">
    <slot />
  </div>

  <script>
    import { supabase } from "../../lib/supabase";

    const logoutBtn = document.getElementById("adminLogoutBtn");
    const mobileAdminNav = document.getElementById("mobileAdminNav");

    if (logoutBtn) {
      logoutBtn.addEventListener("click", async () => {
        await supabase.auth.signOut();
        window.location.href = "/admin/login/";
      });
    }

    if (mobileAdminNav) {
      mobileAdminNav.addEventListener("change", (event) => {
        const target = event.target;
        if (target.value && target.value !== "#") {
          window.location.href = target.value;
        }
      });
    }

    const publishButtons = [
      document.getElementById("adminPublishBtn"),
      document.getElementById("adminPublishBtnMobile"),
    ].filter(Boolean);
    const publishStatus = document.getElementById("adminPublishStatus");

    function setPublishStatus(text, tone) {
      if (!publishStatus) return;
      publishStatus.classList.remove("hidden", "text-amber-300", "text-green-300", "text-red-300");
      publishStatus.classList.add(
        tone === "error" ? "text-red-300" : tone === "success" ? "text-green-300" : "text-amber-300"
      );
      publishStatus.textContent = text;
    }

    async function triggerPublish() {
      const { data } = await supabase.auth.getSession();
      const token = data.session?.access_token;

      if (!token) {
        window.location.href = "/admin/login/";
        return;
      }

      publishButtons.forEach((b) => (b.disabled = true));
      setPublishStatus("در حال انتشار…", "pending");

      try {
        const res = await fetch("/.netlify/functions/trigger-deploy", {
          method: "POST",
          headers: { Authorization: `Bearer ${token}` },
        });

        if (!res.ok) throw new Error(await res.text());

        setPublishStatus("انتشار شروع شد ✅ تا ~۱ دقیقه دیگر زنده می‌شود.", "success");
      } catch (error) {
        setPublishStatus("خطا در انتشار. کمی بعد دوباره تلاش کن.", "error");
      } finally {
        publishButtons.forEach((b) => (b.disabled = false));
      }
    }

    publishButtons.forEach((b) => b.addEventListener("click", triggerPublish));
  </script>
</div>
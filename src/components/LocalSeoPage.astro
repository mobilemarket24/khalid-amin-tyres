---
import BaseLayout from "../layouts/BaseLayout.astro";
import { business } from "../data/business";
import { getWhatsAppUrl } from "../utils/whatsapp";

interface FAQ {
  question: string;
  answer: string;
}

interface RelatedLink {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  h1: string;
  intro: string;
  city: "Dubai" | "Sharjah";
  branch: "dubai" | "sharjah";
  serviceName: string;
  heroImage: string;
  primaryMessage: string;
  bullets: string[];
  faqs: FAQ[];
  relatedLinks: RelatedLink[];
}

const {
  title,
  description,
  eyebrow,
  h1,
  intro,
  city,
  branch,
  serviceName,
  heroImage,
  primaryMessage,
  bullets,
  faqs,
  relatedLinks,
} = Astro.props;

const branchData = business.branches[branch];
const whatsappUrl = getWhatsAppUrl(branch, primaryMessage);

const serviceItems = [
  "Tyre fitting",
  "Wheel balancing",
  "Wheel alignment",
  "Rims and alloy wheels",
  "Battery service",
  "Fast WhatsApp price support",
];
---

<BaseLayout title={title} description={description}>
  <main class="bg-slate-50 text-slate-950">
    <section class="relative overflow-hidden bg-[#0a0a0e] text-white">
      <div class="absolute inset-0">
        <img
          src={heroImage}
          alt={h1}
          class="h-full w-full object-cover object-center opacity-45"
        />
      </div>

      <div class="absolute inset-0 bg-gradient-to-r from-[#020617]/95 via-[#020617]/82 to-[#020617]/40"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#0a0a0e]"></div>

      <div class="relative mx-auto max-w-7xl px-5 py-16 lg:py-24">
        <div class="max-w-3xl">
          <p class="inline-flex rounded-2xl border border-amber-300/20 bg-amber-400/10 px-4 py-2 text-xs font-black uppercase tracking-[0.25em] text-amber-300">
            {eyebrow}
          </p>

          <h1 class="mt-6 text-5xl font-black leading-tight tracking-tight sm:text-6xl lg:text-7xl">
            {h1}
          </h1>

          <p class="mt-6 max-w-2xl text-lg font-semibold leading-8 text-slate-200">
            {intro}
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href={whatsappUrl}
              class="rounded-2xl bg-amber-400 px-7 py-4 text-center font-black text-slate-950 shadow-xl shadow-amber-400/20 transition hover:bg-amber-300"
            >
              Get Today’s Price on WhatsApp
            </a>

            <a
              href="#branch"
              class="rounded-2xl border border-white/15 bg-white/10 px-7 py-4 text-center font-black text-white backdrop-blur transition hover:bg-white/15"
            >
              View {city} Branch
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="px-5 py-14">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1fr_0.85fr]">
        <div class="rounded-[2rem] bg-white p-7 shadow-sm ring-1 ring-slate-200">
          <p class="text-sm font-black uppercase tracking-[0.25em] text-amber-600">
            {serviceName} in {city}
          </p>

          <h2 class="mt-3 text-4xl font-black tracking-tight">
            Fast {serviceName.toLowerCase()} support in {city}
          </h2>

          <p class="mt-5 text-base font-semibold leading-8 text-slate-600">
            Khalid Amin Tyres helps drivers in {city} get the right tyres, rims
            and wheel services with fast WhatsApp support, professional fitting
            and clear branch information.
          </p>

          <div class="mt-7 grid gap-3 sm:grid-cols-2">
            {
              bullets.map((item) => (
                <p class="flex items-start gap-3 rounded-2xl bg-slate-50 p-4 text-sm font-bold text-slate-700">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-amber-400 text-xs font-black text-slate-950">
                    ✓
                  </span>
                  {item}
                </p>
              ))
            }
          </div>
        </div>

        <div id="branch" class="rounded-[2rem] bg-[#0a0a0e] p-7 text-white shadow-xl">
          <p class="text-sm font-black uppercase tracking-[0.25em] text-red-300">
            {city} Branch
          </p>

          <h2 class="mt-3 text-3xl font-black">
            Visit Khalid Amin Tyres in {city}
          </h2>

          <div class="mt-6 space-y-4">
            <div class="rounded-2xl bg-white/10 p-5">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">
                Address
              </p>
              <p class="mt-2 text-sm font-semibold leading-7 text-slate-200">
                {branchData.address}
              </p>
            </div>

            <div class="rounded-2xl bg-white/10 p-5">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">
                Working Hours
              </p>
              <p class="mt-2 text-sm font-semibold text-slate-200">
                {branchData.hours}
              </p>
            </div>

            <div class="rounded-2xl bg-white/10 p-5">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">
                WhatsApp
              </p>
              <p class="mt-2 text-xl font-black text-white">
                {branchData.whatsappLocal}
              </p>
            </div>
          </div>

          <a
            href={whatsappUrl}
            class="mt-6 flex justify-center rounded-2xl bg-red-500 px-6 py-4 text-center font-black text-white transition hover:bg-red-400"
          >
            WhatsApp {city} Branch
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white px-5 py-14">
      <div class="mx-auto max-w-7xl">
        <div class="text-center">
          <p class="text-sm font-black uppercase tracking-[0.25em] text-amber-600">
            Services
          </p>

          <h2 class="mt-3 text-4xl font-black tracking-tight">
            More services at Khalid Amin Tyres
          </h2>
        </div>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            serviceItems.map((item) => (
              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-center text-sm font-black">
                {item}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-5 py-14">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.25em] text-amber-600">
            FAQ
          </p>

          <h2 class="mt-3 text-4xl font-black tracking-tight">
            Common questions
          </h2>

          <p class="mt-4 text-sm font-semibold leading-7 text-slate-600">
            For the fastest answer, send your tyre size, rim size or car model on WhatsApp.
          </p>
        </div>

        <div class="space-y-4">
          {
            faqs.map((faq) => (
              <details class="group rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-5">
                  <span class="text-lg font-black text-slate-950">
                    {faq.question}
                  </span>

                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-slate-100 text-xl font-black transition group-open:rotate-45 group-open:bg-amber-400">
                    +
                  </span>
                </summary>

                <p class="mt-4 text-sm font-semibold leading-7 text-slate-600">
                  {faq.answer}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-[#0a0a0e] px-5 py-14 text-white">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-black uppercase tracking-[0.25em] text-amber-300">
          Related pages
        </p>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            relatedLinks.map((link) => (
              <a
                href={link.href}
                class="rounded-2xl border border-white/10 bg-white/10 px-5 py-4 text-sm font-black text-white transition hover:bg-amber-400 hover:text-slate-950"
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

{compact ? (
  <div class="flex items-center">
    <img
      src="/images/logo.png"
      alt="Khalid Amin Tyres"
      class="h-10 w-auto object-contain"
      loading="eager"
    />
  </div>
) : (
  <div class="flex items-center">
    <img
      src="/images/logo.png"
      alt="Khalid Amin Tyres TR CO LLC"
      class="h-14 w-auto object-contain"
      loading="eager"
    />
  </div>
)}

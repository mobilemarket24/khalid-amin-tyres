---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class="flex items-center gap-3">
  <div class="relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-amber-300/40 bg-white/10 shadow-lg shadow-amber-400/10">
    <div class="absolute inset-0 bg-gradient-to-br from-amber-400/30 via-transparent to-red-500/25"></div>

    <svg
      class="relative h-8 w-8"
      viewBox="0 0 64 64"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="32" cy="32" r="27" stroke="#F59E0B" stroke-width="4" />
      <circle cx="32" cy="32" r="15" stroke="#EF4444" stroke-width="4" />
      <circle cx="32" cy="32" r="5" fill="#F59E0B" />
      <path
        d="M16 22L25 32L16 42"
        stroke="white"
        stroke-width="5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M48 22L39 32L48 42"
        stroke="white"
        stroke-width="5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </div>

  {
    !compact && (
      <div>
        <p class="text-base font-black leading-none tracking-tight text-white">
          KHALID AMIN
        </p>
        <p class="mt-1 text-[11px] font-black uppercase tracking-[0.18em] text-amber-300">
          TYRES <span class="text-white/70">TR CO LLC</span>
        </p>
      </div>
    )
  }
</div>
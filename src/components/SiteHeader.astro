---
import BrandLogo from "./BrandLogo.astro";
import DynamicSiteText from "./DynamicSiteText.astro";
import { business } from "../data/business";
import { getWhatsAppUrl } from "../utils/whatsapp";
import { getBrandsByCategory } from "../lib/brands";

const isAr = Astro.url.pathname.startsWith("/ar");

const homeUrl = isAr ? "/ar/" : "/";
const langUrl = isAr ? "/" : "/ar/";

// Tyres are organised by tyre brand, rims by car make — both managed from the
// admin Brands page (category field) and refreshed live below.
const tyreBrands = await getBrandsByCategory("tyre");
const rimBrands = await getBrandsByCategory("rim");

const tyreBrandLinks = tyreBrands.map((b) => ({ label: b.name, href: `/tyres/${b.slug}/` }));
const rimBrandLinks = rimBrands.map((b) => ({ label: b.name, href: `/rims/${b.slug}/` }));

const serviceLinks = isAr
  ? [
      { label: "ضبط الزوايا - دبي", href: "/wheel-alignment-dubai/" },
      { label: "ضبط الزوايا - الشارقة", href: "/wheel-alignment-sharjah/" },
      { label: "ميزان العجلات - دبي", href: "/wheel-balancing-dubai/" },
      { label: "ميزان العجلات - الشارقة", href: "/wheel-balancing-sharjah/" },
      { label: "تركيب الإطارات", href: "/ar/#services" },
      { label: "البطاريات", href: "/ar/#services" },
    ]
  : [
      { label: "Wheel Alignment - Dubai", href: "/wheel-alignment-dubai/" },
      { label: "Wheel Alignment - Sharjah", href: "/wheel-alignment-sharjah/" },
      { label: "Wheel Balancing - Dubai", href: "/wheel-balancing-dubai/" },
      { label: "Wheel Balancing - Sharjah", href: "/wheel-balancing-sharjah/" },
      { label: "Tyre Fitting", href: "/#services" },
      { label: "Batteries", href: "/#services" },
    ];

const branchLinks = isAr
  ? [
      { label: "فرع دبي", href: "/tyres-dubai/" },
      { label: "فرع الشارقة", href: "/tyres-sharjah/" },
    ]
  : [
      { label: "Dubai Branch", href: "/tyres-dubai/" },
      { label: "Sharjah Branch", href: "/tyres-sharjah/" },
    ];

interface NavChild {
  label: string;
  href: string;
}

interface NavGroup {
  labelKey: string;
  fallbackLabel: string;
  href: string;
  children?: NavChild[];
  wide?: boolean;
  brandType?: "tyres" | "rims";
}

const navGroups: NavGroup[] = isAr
  ? [
      { labelKey: "header_ar_nav_home", fallbackLabel: "الرئيسية", href: "/ar/" },
      { labelKey: "header_ar_nav_tyres", fallbackLabel: "الإطارات", href: "/ar/#tyres", children: tyreBrandLinks, wide: true, brandType: "tyres" },
      { labelKey: "header_ar_nav_rims", fallbackLabel: "الجنوط", href: "/ar/#rims", children: rimBrandLinks, wide: true, brandType: "rims" },
      { labelKey: "header_ar_nav_services", fallbackLabel: "الخدمات", href: "/ar/#services", children: serviceLinks },
      { labelKey: "header_ar_nav_branches", fallbackLabel: "الفروع", href: "/ar/#branches", children: branchLinks },
      { labelKey: "header_ar_nav_faq", fallbackLabel: "الأسئلة", href: "/ar/#faq" },
      { labelKey: "header_ar_nav_contact", fallbackLabel: "تواصل معنا", href: "/ar/#contact" },
    ]
  : [
      { labelKey: "header_nav_home", fallbackLabel: "Home", href: "/" },
      { labelKey: "header_nav_tyres", fallbackLabel: "Tyres", href: "/#tyres", children: tyreBrandLinks, wide: true, brandType: "tyres" },
      { labelKey: "header_nav_rims", fallbackLabel: "Rims", href: "/#rims", children: rimBrandLinks, wide: true, brandType: "rims" },
      { labelKey: "header_nav_services", fallbackLabel: "Services", href: "/#services", children: serviceLinks },
      { labelKey: "header_nav_branches", fallbackLabel: "Branches", href: "/#branches", children: branchLinks },
      { labelKey: "header_nav_faq", fallbackLabel: "FAQ", href: "/#faq" },
      { labelKey: "header_nav_contact", fallbackLabel: "Contact", href: "/#contact" },
    ];

const text = isAr
  ? {
      logoKey: "header_ar_logo_text",
      logoFallback: "خالد أمين تايرز",
      locationKey: "header_ar_location_text",
      locationFallback: "دبي والشارقة",
      quoteKey: "header_ar_quote_button",
      quoteFallback: "احصل على السعر",
      langKey: "header_language_en",
      langFallback: "English",
      mobileMenu: "القائمة",
      whatsappKey: "header_ar_mobile_whatsapp",
      whatsappFallback: "واتساب",
    }
  : {
      logoKey: "header_logo_text",
      logoFallback: business.name,
      locationKey: "header_location_text",
      locationFallback: "Dubai & Sharjah",
      quoteKey: "header_quote_button",
      quoteFallback: "Get Price",
      langKey: "header_language_ar",
      langFallback: "عربي",
      mobileMenu: "Menu",
      whatsappKey: "header_mobile_whatsapp",
      whatsappFallback: "WhatsApp",
    };
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0e]/90 text-white shadow-2xl shadow-slate-950/20 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-5">
    <div class="flex h-20 items-center justify-between gap-5">
      <a href={homeUrl} class="flex items-center gap-3">
        <BrandLogo />

        <div class="hidden sm:block">
          <DynamicSiteText
            textKey={text.logoKey}
            fallback={text.logoFallback}
            as="p"
            class="text-sm font-black leading-tight tracking-wide text-white"
          />

          <DynamicSiteText
            textKey={text.locationKey}
            fallback={text.locationFallback}
            as="p"
            class="mt-1 text-xs font-bold text-slate-400"
          />
        </div>
      </a>

      <nav class="hidden items-center gap-1 lg:flex">
        {
          navGroups.map((item) =>
            item.children ? (
              <div class="group relative">
                <a
                  href={item.href}
                  class="flex items-center gap-1 rounded-xl px-3 py-3 text-sm font-black text-slate-200 transition hover:bg-white/10 hover:text-amber-300 xl:px-4"
                >
                  <DynamicSiteText textKey={item.labelKey} fallback={item.fallbackLabel} as="span" />
                  <span class="text-[10px] opacity-70 transition group-hover:rotate-180">▾</span>
                </a>

                <div
                  class={`invisible absolute top-full z-50 ${isAr ? "right-0" : "left-0"} pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100`}
                >
                  <div
                    class={`max-h-[70vh] overflow-auto rounded-2xl border border-white/10 bg-[#0e0e14] p-3 shadow-2xl shadow-black/50 ${item.wide ? "grid w-[420px] grid-cols-2 gap-1" : "grid w-56 gap-1"}`}
                    data-brand-list={item.brandType}
                    data-link-class="rounded-xl px-3 py-2 text-sm font-bold text-slate-300 transition hover:bg-amber-400/10 hover:text-amber-300"
                  >
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="rounded-xl px-3 py-2 text-sm font-bold text-slate-300 transition hover:bg-amber-400/10 hover:text-amber-300"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="rounded-xl px-3 py-3 text-sm font-black text-slate-200 transition hover:bg-white/10 hover:text-amber-300 xl:px-4"
              >
                <DynamicSiteText textKey={item.labelKey} fallback={item.fallbackLabel} as="span" />
              </a>
            )
          )
        }
      </nav>

      <div class="hidden items-center gap-3 lg:flex">
        <a
          href="/admin/login/"
          class="rounded-xl border border-amber-400/30 bg-amber-400/10 px-4 py-3 text-sm font-black text-amber-300 transition hover:border-amber-300/60 hover:bg-amber-400/20"
        >
          {isAr ? "الإدارة" : "Admin"}
        </a>

        <a
          href={langUrl}
          class="rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-black text-white transition hover:border-amber-300/50 hover:bg-amber-400/10 hover:text-amber-300"
        >
          <DynamicSiteText textKey={text.langKey} fallback={text.langFallback} as="span" />
        </a>

        <a
          href={getWhatsAppUrl(
            "sharjah",
            isAr ? "مرحبا، أريد معرفة السعر والتوفر." : "Hi, I need price and availability."
          )}
          class="rounded-xl bg-amber-400 px-5 py-3 text-sm font-black text-slate-950 shadow-lg shadow-amber-400/20 transition hover:bg-amber-300"
        >
          <DynamicSiteText textKey={text.quoteKey} fallback={text.quoteFallback} as="span" />
        </a>
      </div>

      <button
        type="button"
        id="siteMobileMenuButton"
        class="flex h-12 w-12 items-center justify-center rounded-2xl border border-white/10 bg-white/10 text-2xl font-black text-white lg:hidden"
        aria-label={text.mobileMenu}
      >
        ☰
      </button>
    </div>

    <div id="siteMobileMenu" class="hidden border-t border-white/10 py-4 lg:hidden">
      <nav class="grid gap-2">
        {
          navGroups.map((item) =>
            item.children ? (
              <div class="rounded-2xl bg-white/5">
                <button
                  type="button"
                  class="mobile-accordion-btn flex w-full items-center justify-between px-4 py-4 text-sm font-black text-white"
                >
                  <DynamicSiteText textKey={item.labelKey} fallback={item.fallbackLabel} as="span" />
                  <span class="accordion-icon text-xs opacity-70">▾</span>
                </button>

                <div class="mobile-accordion-panel hidden px-3 pb-3">
                  <a
                    href={item.href}
                    class="block rounded-xl px-3 py-3 text-sm font-black text-amber-300 hover:bg-white/10"
                  >
                    {isAr ? "عرض الكل" : "View all"}
                  </a>
                  <div
                    class="grid grid-cols-2 gap-1"
                    data-brand-list={item.brandType}
                    data-link-class="rounded-xl px-3 py-3 text-sm font-bold text-slate-300 transition hover:bg-white/10 hover:text-amber-300"
                  >
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="rounded-xl px-3 py-3 text-sm font-bold text-slate-300 transition hover:bg-white/10 hover:text-amber-300"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="rounded-2xl bg-white/5 px-4 py-4 text-sm font-black text-white transition hover:bg-white/10 hover:text-amber-300"
              >
                <DynamicSiteText textKey={item.labelKey} fallback={item.fallbackLabel} as="span" />
              </a>
            )
          )
        }

        <a
          href="/admin/login/"
          class="mt-2 rounded-2xl border border-amber-400/30 bg-amber-400/10 px-4 py-4 text-center text-sm font-black text-amber-300"
        >
          {isAr ? "تسجيل دخول الإدارة" : "Admin Login"}
        </a>

        <div class="grid grid-cols-2 gap-2 pt-2">
          <a
            href={langUrl}
            class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 text-center text-sm font-black text-white"
          >
            <DynamicSiteText textKey={text.langKey} fallback={text.langFallback} as="span" />
          </a>

          <a
            href={getWhatsAppUrl(
              "sharjah",
              isAr ? "مرحبا، أريد معرفة السعر والتوفر." : "Hi, I need price and availability."
            )}
            class="rounded-2xl bg-amber-400 px-4 py-4 text-center text-sm font-black text-slate-950"
          >
            <DynamicSiteText textKey={text.whatsappKey} fallback={text.whatsappFallback} as="span" />
          </a>
        </div>
      </nav>
    </div>
  </div>

  <script>
    const mobileMenuButton = document.querySelector("#siteMobileMenuButton");
    const mobileMenu = document.querySelector("#siteMobileMenu");

    mobileMenuButton?.addEventListener("click", () => {
      mobileMenu?.classList.toggle("hidden");
    });

    // Accordion toggles inside the mobile menu
    document.querySelectorAll(".mobile-accordion-btn").forEach((button) => {
      button.addEventListener("click", () => {
        const panel = button.nextElementSibling;
        const icon = button.querySelector(".accordion-icon");
        panel?.classList.toggle("hidden");
        icon?.classList.toggle("rotate-180");
      });
    });

    // Close the whole menu when a real link (not an accordion toggle) is clicked
    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
      });
    });
  </script>

  <script>
    // Live brand menus: refresh the Tyres/Rims dropdowns from Supabase so brands
    // added or hidden in the admin appear instantly (the dedicated brand pages
    // themselves are static and regenerate on the next deploy).
    import { createClient } from "@supabase/supabase-js";

    const headerSupabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      {
        auth: {
          persistSession: false,
          autoRefreshToken: false,
          detectSessionInUrl: false,
        },
      }
    );

    function escapeHtmlAttr(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function brandCategory(b) {
      const v = String(b.category || "").toLowerCase();
      return v === "rim" || v === "both" ? v : "tyre";
    }

    async function refreshBrandMenus() {
      const lists = Array.from(document.querySelectorAll("[data-brand-list]"));
      if (!lists.length) return;

      // select("*") is resilient whether or not the `category` column exists.
      const { data, error } = await headerSupabase
        .from("brands")
        .select("*")
        .eq("is_active", true)
        .order("sort_order", { ascending: true })
        .order("name", { ascending: true });

      if (error || !data || data.length === 0) return;

      const valid = data.filter((b) => b.slug && b.name);
      const tyreBrands = valid.filter((b) => {
        const c = brandCategory(b);
        return c === "tyre" || c === "both";
      });
      const rimBrands = valid.filter((b) => {
        const c = brandCategory(b);
        return c === "rim" || c === "both";
      });

      lists.forEach((el) => {
        const type = el.getAttribute("data-brand-list"); // "tyres" | "rims"
        if (type !== "tyres" && type !== "rims") return;

        const items = type === "rims" ? rimBrands : tyreBrands;
        // Don't wipe the build-time fallback list if this category has no rows
        // yet (e.g. before the category column/seed exists).
        if (!items.length) return;

        const linkClass = el.getAttribute("data-link-class") || "";

        el.innerHTML = items
          .map(
            (b) =>
              `<a href="/${type}/${escapeHtmlAttr(b.slug)}/" class="${linkClass}">${escapeHtmlAttr(b.name)}</a>`
          )
          .join("");
      });
    }

    refreshBrandMenus();
  </script>
</header>
